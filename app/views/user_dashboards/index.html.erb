<div class="max-w-6xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 mb-8 lg:mb-10 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div>
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Panel de Control</h1>
      <p class="text-gray-400 text-sm mt-1">Bienvenido a tu gestión de salud biomecánica, <span class="text-orange-500 font-bold"><%= current_user.first_name %> <%= current_user.last_name %></span>.</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 lg:gap-6 max-w-7xl mx-auto">

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 flex flex-col justify-between relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div>
        <div class="flex justify-between items-center mb-5">
          <h3 class="text-lg font-bold text-white m-0">Estudios</h3>
          <% total = (@work_total || 0) %>
          <% if is_paciente? %>
            <span class="bg-yellow-500/10 text-yellow-400 text-[10px] font-bold uppercase px-3 py-1 rounded-full border border-yellow-500/20"><%= "#{total} pendientes" %></span>
          <% elsif is_medico? %>
            <span class="bg-blue-500/10 text-blue-400 text-[10px] font-bold uppercase px-3 py-1 rounded-full border border-blue-500/20"><%= "#{total} asignados" %></span>
          <% else %>
            <span class="bg-orange-500/10 text-orange-400 text-[10px] font-bold uppercase px-3 py-1 rounded-full border border-orange-500/20"><%= "#{total} en total" %></span>
          <% end %>
        </div>
      </div>
      <% if is_paciente? %>
        <%= link_to "Ver mis estudios", admin_estudios_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-4 py-3 rounded-xl text-sm font-black uppercase tracking-wider text-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] block" %>
      <% elsif is_medico? || is_recepcionista? || is_administrador? %>
        <%= link_to "Gestionar agenda", admin_estudios_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-4 py-3 rounded-xl text-sm font-black uppercase tracking-wider text-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] block" %>
      <% end %>
    </div>

    <% if is_paciente? %>
    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div>
        <h3 class="text-lg font-bold text-white mb-5">Último Estudio</h3>
        <% if @ultimo_estudio %>
        <div class="flex items-center gap-2.5 py-2.5 border-b border-white/5">
          <div class="w-2 h-2 bg-orange-500 rounded-full shrink-0"></div>
          <span class="text-sm font-semibold text-gray-300"><%= @ultimo_estudio.nombre_completo %></span>
          <span class="text-xs text-gray-500 ml-auto"><%= @ultimo_estudio.fecha_estudio&.strftime("%d %b %Y") %></span>
        </div>
        <% else %>
        <p class="text-sm text-gray-500 m-0">No tienes estudios registrados.</p>
        <% end %>
      </div>
      <%= link_to "Ver historial completo", admin_estudios_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-4 py-3 rounded-xl text-sm font-black uppercase tracking-wider text-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] block mt-5" %>
    </div>
    <% end %>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div>
        <h3 class="text-lg font-bold text-white mb-5">Mi Estado</h3>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-3 h-3 rounded-full <%= User::STATUS_COLORS[current_user.status] || 'bg-gray-600' %>"></div>
          <span class="text-sm font-bold text-gray-300"><%= current_user.status_label %></span>
        </div>
        <p class="text-sm text-gray-500 leading-relaxed m-0">Puedes cambiar tu estado desde la configuración de perfil.</p>
      </div>
      <%= link_to "Ir a mi perfil", profile_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-4 py-3 rounded-xl text-sm font-black uppercase tracking-wider text-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] block mt-5" %>
    </div>

  </div>
</div>
