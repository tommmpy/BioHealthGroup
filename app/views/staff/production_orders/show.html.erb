<% sc = {
  "pending" => { label: "Pendiente", color: "#ff9f00" },
  "in_progress" => { label: "En producción", color: "#00a3ff" },
  "completed" => { label: "Completada", color: "#00ff85" },
  "cancelled" => { label: "Cancelada", color: "#ff4444" }
} %>
<% status = sc[@production_order.status] || sc.values.first %>

<div class="max-w-5xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-8">
    <div>
      <%= link_to staff_production_orders_path, class: "text-gray-500 no-underline text-sm flex items-center gap-1 mb-3 transition-colors duration-200 hover:text-orange-400" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver a órdenes
      <% end %>
      <h1 class="text-3xl lg:text-4xl font-black m-0 tracking-tight">Orden de Producción #<%= @production_order.id %></h1>
      <p class="text-gray-500 mt-1 text-sm">Creada el <%= l(@production_order.created_at, format: :long) %></p>
    </div>
    <div class="text-right">
      <span class="text-black px-5 py-2 rounded-full text-xs font-bold uppercase tracking-wider whitespace-nowrap shadow-lg" style="background: <%= status[:color] %>; box-shadow: 0 0 20px <%= status[:color] %>40;">
        <%= status[:label] %>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-5 lg:gap-6">

    <div class="flex flex-col gap-5 lg:gap-6">
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <h3 class="text-orange-500 text-xs uppercase tracking-widest font-bold mb-5">Estudio Asociado</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-5">
          <div>
            <label class="text-gray-500 text-[11px] block mb-1">Paciente</label>
            <%= link_to admin_estudio_path(@production_order.estudio), class: "text-lg font-bold text-white no-underline hover:text-orange-400 transition-colors" do %>
              <%= @production_order.estudio.nombre_completo %>
            <% end %>
          </div>
          <div>
            <label class="text-gray-500 text-[11px] block mb-1">CI</label>
            <span class="text-gray-400"><%= @production_order.estudio.user&.ci || "—" %></span>
          </div>
          <div>
            <label class="text-gray-500 text-[11px] block mb-1">Productos</label>
            <div class="flex flex-wrap gap-1.5 mt-1">
              <% Array(@production_order.estudio.tipo_producto).each do |prod| %>
                <span class="bg-white/5 text-gray-400 border border-white/10 px-2.5 py-0.5 rounded-full text-[11px]"><%= prod %></span>
              <% end %>
            </div>
          </div>
          <div>
            <label class="text-gray-500 text-[11px] block mb-1">Sucursal</label>
            <span class="text-gray-400"><%= @production_order.estudio.branch&.name %></span>
          </div>
        </div>
      </div>

      <% if @production_order.assigned_to.present? %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <h3 class="text-orange-500 text-xs uppercase tracking-widest font-bold mb-5">Operario Asignado</h3>
          <div class="flex items-center gap-4">
            <div class="bg-gradient-to-br from-orange-500 to-orange-600 w-12 h-12 rounded-full flex items-center justify-center text-lg font-black text-black shadow-lg shadow-orange-500/20 shrink-0">
              <%= @production_order.assigned_to.first_name[0] %><%= @production_order.assigned_to.last_name[0] %>
            </div>
            <div class="min-w-0">
              <span class="text-lg font-bold"><%= @production_order.assigned_to.name %></span>
              <div class="text-gray-500 text-sm mt-1 truncate"><%= @production_order.assigned_to.email_address %></div>
            </div>
          </div>
        </div>
      <% end %>

      <% if @production_order.notes.present? %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <h3 class="text-orange-500 text-xs uppercase tracking-widest font-bold mb-5">Notas</h3>
          <p class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap"><%= @production_order.notes %></p>
        </div>
      <% end %>
    </div>

    <div class="flex flex-col gap-5 lg:gap-6">
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <h3 class="text-gray-500 text-xs uppercase tracking-widest mb-4">Detalles</h3>
        <div class="flex flex-col gap-3 text-sm">
          <div class="flex justify-between py-2 border-b border-white/5">
            <span class="text-gray-500">Estado</span>
            <span class="font-bold" style="color: <%= status[:color] %>"><%= status[:label] %></span>
          </div>
          <% if @production_order.due_date.present? %>
            <div class="flex justify-between py-2 border-b border-white/5">
              <span class="text-gray-500">Fecha de vencimiento</span>
              <span class="font-bold <%= @production_order.due_date < Date.current && !@production_order.completed? ? 'text-red-400' : 'text-white' %>"><%= l(@production_order.due_date, format: :default) %></span>
            </div>
          <% end %>
          <% if @production_order.completed_at.present? %>
            <div class="flex justify-between py-2 border-b border-white/5">
              <span class="text-gray-500">Completada el</span>
              <span class="font-bold text-white"><%= l(@production_order.completed_at, format: :long) %></span>
            </div>
          <% end %>
          <div class="flex justify-between py-2">
            <span class="text-gray-500">Creada</span>
            <span class="font-bold text-white"><%= l(@production_order.created_at.to_date, format: :default) %></span>
          </div>
        </div>
      </div>

      <% if is_administrador? && @production_order.pending? %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <h3 class="text-gray-500 text-xs uppercase tracking-widest mb-4">Asignar Operario</h3>
          <%= form_with model: @production_order, url: staff_production_order_path(@production_order), method: :patch, local: true do |f| %>
            <div class="flex flex-col gap-3">
              <%= f.collection_select :assigned_to_id, User.where(role: User.roles[:operario]).order(:first_name), :id, ->(u) { "#{u.first_name} #{u.last_name}" }, { prompt: "Seleccionar operario...", selected: @production_order.assigned_to_id }, class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
              <%= f.submit "Asignar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-3 rounded-xl text-sm font-black cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] active:scale-[0.98]" %>
            </div>
          <% end %>
        </div>
      <% end %>

      <div class="flex flex-col gap-2.5">
        <% if @production_order.pending? && (is_administrador? || is_operario?) %>
          <%= button_to "INICIAR PRODUCCIÓN", start_staff_production_order_path(@production_order),
              method: :patch,
              class: "w-full bg-gradient-to-r from-blue-500 to-blue-600 text-white border-none py-4 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-blue-500/25 transition-all duration-300 hover:shadow-blue-500/40 hover:scale-[1.02] active:scale-[0.98]" %>
        <% elsif @production_order.in_progress? && (is_administrador? || is_operario?) %>
          <%= button_to "COMPLETAR PRODUCCIÓN", complete_staff_production_order_path(@production_order),
              method: :patch,
              class: "w-full bg-gradient-to-r from-green-500 to-green-600 text-black border-none py-4 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-green-500/25 transition-all duration-300 hover:shadow-green-500/40 hover:scale-[1.02] active:scale-[0.98]" %>
        <% elsif @production_order.completed? %>
          <div class="w-full border border-white/10 py-4 rounded-xl text-center text-black font-bold text-xs shadow-lg" style="background: <%= status[:color] %>; box-shadow: 0 0 20px <%= status[:color] %>40;">
            PRODUCCIÓN COMPLETADA
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
