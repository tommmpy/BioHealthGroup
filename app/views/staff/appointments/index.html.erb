<div class="w-full mx-auto px-3 sm:px-4 lg:px-10 py-4 sm:py-6 lg:py-8 animate-fade-up">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 sm:mb-8 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Gestión de Turnos</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @appointments.count %> TURNOS
      </div>
    </div>
    <% if is_administrador? || is_recepcionista? %>
      <%= link_to new_staff_appointment_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 inline-flex items-center gap-2 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 shrink-0" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
        Nuevo turno
      <% end %>
    <% end %>
  </div>

  <%# Filtros %>
  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-5 mb-5 relative"
       style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <%= form_with url: staff_appointments_path, method: :get, local: true, class: "flex flex-wrap items-end gap-3" do |f| %>
      <div class="flex flex-col gap-1">
        <%= f.label :date, "Fecha", class: "text-[11px] font-bold text-gray-500 uppercase tracking-wider" %>
        <%= f.date_field :date, value: params[:date], class: "p-2.5 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>
      <div class="flex flex-col gap-1">
        <%= f.label :status, "Estado", class: "text-[11px] font-bold text-gray-500 uppercase tracking-wider" %>
        <%= f.select :status, options_for_select(Appointment::STATUS_LABELS.invert.sort_by { |_, k| k }, params[:status]), { include_blank: "Todos" }, class: "p-2.5 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>
      <% if !is_paciente? %>
        <div class="flex flex-col gap-1">
          <%= f.label :branch_id, "Sucursal", class: "text-[11px] font-bold text-gray-500 uppercase tracking-wider" %>
          <%= f.select :branch_id, options_from_collection_for_select(@branches, :id, :name, params[:branch_id]), { include_blank: "Todas" }, class: "p-2.5 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
        </div>
      <% end %>
      <div class="flex gap-2">
        <%= f.submit "Filtrar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-4 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/20 transition-all duration-300 hover:shadow-orange-500/30 hover:scale-105" %>
        <%= link_to "Limpiar", staff_appointments_path, class: "border border-white/10 text-gray-400 no-underline px-4 py-2.5 rounded-xl text-xs font-bold transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400" %>
      </div>
    <% end %>
  </div>

  <%# Lista de turnos %>
  <div class="flex flex-col gap-3">
    <% if @appointments.any? %>
      <% @appointments.each do |appointment| %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-5 relative transition-all duration-200 hover:border-orange-500/20"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-3">
            <div class="flex items-center gap-3 sm:gap-4 min-w-0 flex-1">
              <div class="flex flex-col items-center justify-center w-14 h-14 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 shrink-0 shadow-lg shadow-orange-500/20">
                <span class="text-[10px] font-black text-black leading-none uppercase"><%= appointment.starts_at.strftime("%b") %></span>
                <span class="text-lg font-black text-black leading-tight"><%= appointment.starts_at.day %></span>
              </div>
              <div class="min-w-0">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="font-bold text-white text-sm truncate"><%= appointment.title %></span>
                  <span class="<%= Appointment::STATUS_COLORS[appointment.status] || Appointment::STATUS_COLORS.values.first %> text-[10px] font-bold uppercase tracking-wider px-2.5 py-0.5 rounded-full border leading-tight"><%= appointment.status_label %></span>
                </div>
                <div class="text-gray-500 text-xs flex flex-wrap items-center gap-x-2 mt-1">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                    <%= appointment.starts_at.strftime("%H:%M") %> - <%= appointment.ends_at.strftime("%H:%M") %>
                  </span>
                  <span class="text-gray-700">·</span>
                  <span><%= appointment.branch&.name || "Sin sede" %></span>
                </div>
                <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mt-1.5 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                    <%= appointment.user.first_name %> <%= appointment.user.last_name %>
                  </span>
                  <% if appointment.medico.present? %>
                    <span class="text-gray-700">·</span>
                    <span>Dr. <%= appointment.medico.first_name %> <%= appointment.medico.last_name %></span>
                  <% end %>
                </div>
              </div>
            </div>
            <div class="flex items-center gap-2 sm:flex-col sm:items-stretch shrink-0">
              <% if appointment.pending? && (is_administrador? || is_recepcionista?) %>
                <%= button_to "Confirmar", confirm_staff_appointment_path(appointment), method: :patch,
                    class: "bg-gradient-to-r from-blue-500 to-blue-600 text-white border-none px-4 py-2 rounded-lg text-[11px] font-bold cursor-pointer shadow-lg shadow-blue-500/20 transition-all duration-200 hover:shadow-blue-500/30 hover:scale-105 whitespace-nowrap" %>
              <% end %>
              <% if !appointment.cancelled? && !appointment.completed? && (is_administrador? || is_recepcionista? || (is_medico? && appointment.medico_id == current_user.id)) %>
                <%= button_to "Cancelar", cancel_staff_appointment_path(appointment), method: :patch,
                    form: { data: { turbo_confirm: "¿Confirma que desea cancelar este turno?" } },
                    class: "border border-red-500/30 text-red-400 bg-transparent px-4 py-2 rounded-lg text-[11px] font-bold cursor-pointer transition-all duration-200 hover:bg-red-500/10 hover:border-red-500/50 whitespace-nowrap" %>
              <% end %>
              <%= link_to "Detalle", staff_appointment_path(appointment),
                  class: "border border-white/10 text-gray-400 no-underline px-4 py-2 rounded-lg text-[11px] font-bold text-center transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400 hover:bg-orange-500/5" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16 text-gray-500 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        <p class="text-sm">No hay turnos registrados.</p>
        <% if is_administrador? || is_recepcionista? %>
          <%= link_to "Agendar primer turno", new_staff_appointment_path, class: "inline-block mt-3 bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
