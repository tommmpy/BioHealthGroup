<div class="max-w-2xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="mb-6 lg:mb-8">
    <%= link_to staff_appointments_path, class: "text-gray-500 no-underline text-sm flex items-center gap-1 mb-3 transition-colors duration-200 hover:text-orange-400" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Volver al listado
    <% end %>
    <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Agendar nuevo turno</h1>
    <p class="text-gray-400 text-sm mt-1">Registra una cita para un paciente en la clínica</p>
  </div>

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <%= form_with model: [:staff, @appointment], local: true do |f| %>
      <% if @appointment.errors.any? %>
        <div class="bg-red-950/80 backdrop-blur border border-red-500/20 p-4 rounded-xl mb-6">
          <p class="text-red-400 text-sm font-bold mb-1">Errores al agendar el turno:</p>
          <ul class="m-0 pl-5 text-gray-300 text-sm">
            <% @appointment.errors.full_messages.each do |msg| %>
              <li class="mb-0.5"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col gap-5 lg:gap-6">

        <%# Título %>
        <div class="flex flex-col gap-2">
          <%= f.label :title, "Motivo de la consulta", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
          <%= f.text_field :title, placeholder: "Ej: Control de rutina, Estudio biomecánico...", required: true,
              class: "p-3 border border-white/10 rounded-xl bg-white/5 text-white text-base w-full box-border outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
        </div>

        <%# === BUSCADOR DE PACIENTES === %>
        <div x-data="{
          q: '',
          results: [],
          selected: null,
          open: false,
          loading: false,
          idx: -1,
          async search() {
            if (!this.q) { this.results = []; this.open = false; return }
            this.loading = true
            let r = await fetch('<%= buscar_pacientes_staff_appointments_path %>?q=' + encodeURIComponent(this.q))
            this.results = await r.json()
            this.open = this.results.length > 0
            this.idx = -1
            this.loading = false
          },
          pick(p) {
            this.selected = p
            this.q = ''
            this.results = []
            this.open = false
            this.idx = -1
            this.$refs.userId.value = p.id
          },
          remove() {
            this.selected = null
            this.$refs.userId.value = ''
          },
          keydown(e) {
            if (!this.open) return
            if (e.key === 'ArrowDown') { e.preventDefault(); this.idx = Math.min(this.idx + 1, this.results.length - 1) }
            else if (e.key === 'ArrowUp') { e.preventDefault(); this.idx = Math.max(this.idx - 1, 0) }
            else if (e.key === 'Enter' && this.idx >= 0) { e.preventDefault(); this.pick(this.results[this.idx]) }
            else if (e.key === 'Escape') { this.open = false }
          }
        }">
          <%= f.hidden_field :user_id, "x-ref": "userId" %>

          <div class="flex flex-col gap-2 relative max-w-md w-full">
            <label class="block mb-2 text-xs font-black text-orange-500 uppercase tracking-wider">Paciente</label>
            <div class="relative">
              <input type="text"
                     x-model="q"
                     @input.debounce.200ms="search()"
                     @focus="if(results.length > 0) open = true"
                     @click.away="open = false"
                     @keydown="keydown($event)"
                     placeholder="Buscar por nombre, apellido o CI..."
                     class="w-full p-3 pr-10 border border-white/10 rounded-xl bg-white/5 text-white text-base outline-none transition-all duration-200 box-border focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]"
                     :style="{ borderColor: selected ? '#22c55e' : (q ? '#ff6b00' : '') }"
              >
              <div class="absolute right-3 top-1/2 -translate-y-1/2">
                <template x-if="loading">
                  <svg class="w-5 h-5 text-gray-500 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                </template>
                <template x-if="!loading && q">
                  <button @click="q = ''; results = []; open = false; idx = -1" class="bg-none border-none text-gray-500 cursor-pointer p-0">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                  </button>
                </template>
                <template x-if="!loading && !q">
                  <svg class="w-[18px] h-[18px] text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                </template>
              </div>
            </div>

            <div x-show="open"
                 x-transition:enter="transition ease-out duration-150"
                 x-transition:enter-start="opacity-0"
                 x-transition:enter-end="opacity-100"
                 class="absolute top-full left-0 right-0 z-50 mt-1 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden shadow-2xl">
              <template x-if="results.length === 0 && q">
                <div class="p-5 text-gray-500 text-sm text-center">
                  Ningún paciente coincide con "<span x-text="q"></span>"
                </div>
              </template>
              <template x-for="(p, i) in results" :key="p.id">
                <div @click="pick(p)"
                     @mouseenter="idx = i"
                     @mouseleave="idx = -1"
                     :class="{ 'bg-white/[0.07]': idx === i }"
                     class="px-4 py-3 cursor-pointer border-b border-white/5 transition-colors duration-100 last:border-0">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center shrink-0">
                      <span class="text-sm font-bold text-gray-400" x-text="(p.first_name || '?')[0] + (p.last_name || '')[0]"></span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="font-semibold text-white" x-text="p.first_name + ' ' + p.last_name"></div>
                      <div class="text-xs text-gray-500 flex gap-3 mt-0.5">
                        <span x-text="'CI: ' + p.ci"></span>
                        <span x-text="p.email" class="truncate"></span>
                      </div>
                    </div>
                  </div>
                </div>
              </template>
            </div>
          </div>

          <div x-show="selected"
               x-transition:enter="transition ease-out duration-300"
               x-transition:enter-start="opacity-0 scale-95"
               x-transition:enter-end="opacity-100 scale-100"
               class="border border-green-500/20 rounded-xl bg-green-500/5 p-3.5 lg:p-4 mt-3">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-green-500/10 border-2 border-green-500/20 flex items-center justify-center shrink-0">
                <svg class="w-[18px] h-[18px] text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              </div>
              <div class="flex-1 min-w-0">
                <div class="font-bold text-white text-sm" x-text="selected.first_name + ' ' + selected.last_name"></div>
                <div class="flex flex-wrap items-center gap-x-4 gap-y-0.5 mt-0.5 text-xs text-gray-500">
                  <span class="flex items-center gap-1">
                    <svg class="w-3 h-3 text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0"/></svg>
                    <span x-text="selected.ci"></span>
                  </span>
                  <a x-show="selected.email" :href="'mailto:' + selected.email" class="flex items-center gap-1 text-gray-500 no-underline hover:text-orange-400" x-text="selected.email">
                  </a>
                </div>
              </div>
              <button @click="remove()" class="bg-none border-none text-gray-500 cursor-pointer p-1 shrink-0 hover:text-red-400 transition-colors">
                <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
              </button>
            </div>
          </div>
        </div>

        <%# Fecha y Hora %>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <%= f.label :starts_at, "Inicio", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
            <%= f.datetime_field :starts_at, class: "p-3 border border-white/10 rounded-xl bg-white/5 text-white text-base w-full box-border outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]", required: true %>
          </div>
          <div class="flex flex-col gap-2">
            <%= f.label :ends_at, "Fin", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
            <%= f.datetime_field :ends_at, class: "p-3 border border-white/10 rounded-xl bg-white/5 text-white text-base w-full box-border outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]", required: true %>
          </div>
        </div>

        <%# Médico %>
        <div class="flex flex-col gap-2">
          <%= f.label :medico_id, "Médico asignado (opcional)", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
          <%= f.collection_select :medico_id, @medicos, :id, ->(m) { "#{m.first_name} #{m.last_name}" }, { include_blank: "Sin médico asignado" }, class: "p-3 border border-white/10 rounded-xl bg-white/5 text-white text-base w-full box-border outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
        </div>

        <%# Sucursal Alpine %>
        <div class="flex flex-col gap-2 relative"
             x-data="{
               open: false,
               selId: '',
               selName: '',
               idx: -1,
               branches: <%= Branch.where(enabled: true).order(:name).map { |b| { id: b.id, name: b.name, address: b.address } }.to_json %>,
               toggle() { this.open = !this.open },
               pick(b) {
                 this.selId = b.id
                 this.selName = b.name
                 this.open = false
                 this.$refs.branchId.value = b.id
               }
             }"
             @click.away="open = false">
          <label class="block mb-2 text-xs font-black text-orange-500 uppercase tracking-wider">Sucursal</label>
          <%= f.hidden_field :branch_id, "x-ref": "branchId" %>

          <div class="relative">
            <div @click="toggle()"
                 class="flex items-center gap-3 w-full p-3 pr-10 border border-white/10 rounded-xl bg-white/5 text-white text-base cursor-pointer box-border transition-all duration-200"
                 :style="{ borderColor: open ? '#ff6b00' : (selId ? '#22c55e' : '') }">
              <svg class="w-[18px] h-[18px] text-gray-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span x-show="!selId" class="text-gray-500">Seleccionar sucursal</span>
              <span x-show="selId" class="text-white font-semibold" x-text="selName"></span>
            </div>
            <div class="absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none">
              <svg class="w-4 h-4 text-gray-500 transition-transform duration-200" :style="{ transform: open ? 'rotate(180deg)' : '' }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </div>
          </div>

          <div x-show="open"
               x-transition:enter="transition ease-out duration-150"
               x-transition:enter-start="opacity-0"
               x-transition:enter-end="opacity-100"
               class="absolute top-full left-0 right-0 z-50 mt-1 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden shadow-2xl max-h-60 overflow-y-auto">
            <template x-for="(b, i) in branches" :key="b.id">
              <div @click="pick(b)"
                   @mouseenter="idx = i"
                   @mouseleave="idx = -1"
                   :class="{ 'bg-white/[0.07]': idx === i }"
                   class="px-4 py-3 cursor-pointer border-b border-white/5 transition-colors duration-100 last:border-0">
                <div class="font-semibold text-white text-sm" x-text="b.name"></div>
                <div class="text-[11px] text-gray-500 mt-0.5" x-text="b.address"></div>
              </div>
            </template>
          </div>
        </div>

        <%# Notas %>
        <div class="flex flex-col gap-2">
          <%= f.label :notes, "Notas (opcional)", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
          <%= f.text_area :notes, rows: 3, placeholder: "Información adicional relevante...",
              class: "p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm w-full box-border outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600 resize-none" %>
        </div>

        <%# Acciones %>
        <div class="flex flex-col sm:flex-row gap-3 mt-2">
          <%= f.submit "Agendar turno", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-4 px-6 rounded-xl text-sm font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] active:scale-[0.98] flex-[2]" %>
          <%= link_to "Cancelar", staff_appointments_path, class: "bg-white/5 text-gray-400 no-underline py-4 px-6 rounded-xl text-sm font-bold text-center border border-white/10 flex-1 transition-all duration-200 hover:text-white hover:border-orange-500/50 hover:bg-orange-500/5" %>
        </div>

      </div>
    <% end %>
  </div>
</div>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>
