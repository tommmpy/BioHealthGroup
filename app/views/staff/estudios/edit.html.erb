<div class="max-w-2xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="mb-6 lg:mb-8">
    <%= link_to staff_estudio_path(@estudio), class: "text-gray-500 no-underline text-sm flex items-center gap-1 transition-colors duration-200 hover:text-orange-400" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Cancelar y volver al detalle
    <% end %>
    <h1 class="text-2xl lg:text-3xl font-black mt-4 tracking-tight">Carga de Resultados <span class="text-orange-500">METAR</span></h1>
  </div>

  <%= form_with(model: [:staff, @estudio], local: true) do |f| %>
    <div class="flex flex-col gap-5 lg:gap-6">

      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
           style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

        <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-3 mb-6 pb-6 border-b border-white/5">
          <div>
            <label class="text-gray-500 text-[11px] uppercase tracking-wider block font-bold mb-1">Paciente</label>
            <span class="font-bold text-base text-white"><%= @estudio.nombre_completo %></span>
          </div>
          <div class="sm:text-right">
            <label class="text-gray-500 text-[11px] uppercase tracking-wider block font-bold mb-1">ID Estudio</label>
            <span class="text-gray-400">#<%= @estudio.id %></span>
          </div>
        </div>

        <div class="border-l-4 border-orange-500 pl-5">
          <label class="text-orange-500 text-xs font-bold uppercase tracking-wider block mb-4">
            Ingresar Código METAR
          </label>
          <%= f.text_field :metar_paciente, 
              placeholder: "Ej: 11/11/11/11",
              autocomplete: "off",
              class: "w-full bg-white/5 border border-white/10 p-5 rounded-xl text-green-400 font-mono text-xl lg:text-2xl font-bold tracking-wider uppercase outline-none box-border transition-all duration-200 focus:border-green-500/50 focus:shadow-[0_0_20px_rgba(0,255,133,0.15)] placeholder-gray-700" 
          %>
          <p class="text-gray-500 text-xs mt-4">
            * Verifique los valores antes de guardar. Este código se imprimirá en el informe oficial.
          </p>
        </div>
      </div>

      <div class="flex gap-3 lg:gap-4 mt-2">
        <%= f.submit "GUARDAR Y FINALIZAR ESTUDIO", 
            class: "flex-[2] bg-gradient-to-r from-green-500 to-green-600 text-black border-none py-[18px] rounded-xl font-black text-sm cursor-pointer shadow-lg shadow-green-500/25 transition-all duration-300 hover:shadow-green-500/40 hover:scale-[1.02] active:scale-[0.98]" 
        %>
      </div>

    </div>
  <% end %>
</div>
