<% section_styles = {
  "red"    => { icon: "text-red-400", bg: "bg-red-500/10", heading: "text-red-400", badge: "text-red-400 bg-red-500/10" },
  "orange" => { icon: "text-orange-400", bg: "bg-orange-500/10", heading: "text-orange-400", badge: "text-orange-400 bg-orange-500/10" },
  "blue"   => { icon: "text-blue-400", bg: "bg-blue-500/10", heading: "text-blue-400", badge: "text-blue-400 bg-blue-500/10" },
  "gray"   => { icon: "text-gray-400", bg: "bg-gray-500/10", heading: "text-gray-400", badge: "text-gray-400 bg-gray-500/10" },
} %>

<% sections = [
  { kinds: %w[reopen_request], title: "Solicitudes de reapertura", color: "red" },
  { kinds: %w[new_ticket ticket_accepted], title: "Nuevos tickets", color: "orange" },
  { kinds: %w[new_message], title: "Mensajes nuevos", color: "blue" },
  { kinds: %w[reopened], title: "Reaperturas", color: "gray" },
] %>

<% grouped = @notifications.group_by(&:kind) %>

<div class="w-full max-w-4xl mx-auto my-6 sm:my-8 lg:my-10 px-3 sm:px-4 animate-fade-up">

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 lg:mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div>
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Notificaciones</h1>
      <p class="text-gray-500 text-sm mt-1">Todas tus notificaciones</p>
    </div>
    <% if current_user.notifications.unread.any? %>
      <%= button_to mark_all_read_notifications_path, method: :patch,
          class: "bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-orange-400 hover:border-orange-500/30 hover:bg-orange-500/10" do %>
        Marcar todo como leído
      <% end %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <% sections.each do |section| %>
      <% items = section[:kinds].flat_map { |k| grouped[k] || [] } %>
      <% next if items.empty? %>
      <% ss = section_styles[section[:color]] %>
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-5 h-5 rounded-lg <%= ss[:bg] %> flex items-center justify-center">
            <% case section[:color] %>
            <% when "red" %>
              <svg class="w-3 h-3 <%= ss[:icon] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01M10.29 3.86l-8.2 14.2A1 1 0 003 20h18a1 1 0 00.86-1.49l-8.2-14.2a1 1 0 00-1.72 0z"/></svg>
            <% when "orange" %>
              <svg class="w-3 h-3 <%= ss[:icon] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            <% when "blue" %>
              <svg class="w-3 h-3 <%= ss[:icon] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
            <% else %>
              <svg class="w-3 h-3 <%= ss[:icon] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <% end %>
          </div>
          <h2 class="text-sm font-black <%= ss[:heading] %> uppercase tracking-wider m-0"><%= section[:title] %></h2>
          <span class="text-[10px] font-black <%= ss[:badge] %> px-2 py-0.5 rounded-full"><%= items.size %></span>
        </div>
        <div class="flex flex-col gap-2">
          <% items.each { |n| concat(render(n)) } %>
        </div>
      </div>
    <% end %>

    <% other_kinds = grouped.keys - sections.flat_map { |s| s[:kinds] } %>
    <% if other_kinds.any? %>
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <div class="w-5 h-5 rounded-lg bg-gray-500/10 flex items-center justify-center">
            <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h2 class="text-sm font-black text-gray-400 uppercase tracking-wider m-0">Otras</h2>
        </div>
        <div class="flex flex-col gap-2">
          <% other_kinds.each { |k| grouped[k].each { |n| concat(render(n)) } } %>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="text-center py-20 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative"
         style="box-shadow: 0 0 20px rgba(255,107,0,0.02), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="w-16 h-16 rounded-2xl bg-white/5 flex items-center justify-center mx-auto mb-4 border border-white/10">
        <svg class="w-7 h-7 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
      </div>
      <p class="text-gray-500 font-semibold">No tenés notificaciones</p>
    </div>
  <% end %>

  <% if defined?(@pagy) && @pagy.present? && @pagy.pages > 1 %>
    <div class="w-full max-w-4xl mx-auto mb-6 lg:mb-8 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>
