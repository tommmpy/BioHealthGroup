<div class="max-w-2xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="mb-6 lg:mb-8">
    <%= link_to conversation_path(@conversation), class: "text-gray-500 no-underline text-sm flex items-center gap-1 mb-3 transition-colors duration-200 hover:text-orange-400" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Volver al ticket
    <% end %>
    <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Editar ticket</h1>
    <p class="text-gray-400 text-sm mt-1">Modifica la información del ticket de soporte</p>
  </div>

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <%= form_with model: @conversation, url: conversation_path(@conversation), method: :patch, local: true, class: "flex flex-col gap-5" do |f| %>
      <% if @conversation.errors.any? %>
        <div class="bg-red-950/80 backdrop-blur border border-red-500/20 p-4 rounded-xl">
          <p class="text-red-400 text-sm font-bold mb-1">Errores:</p>
          <ul class="m-0 pl-5 text-gray-300 text-sm">
            <% @conversation.errors.full_messages.each do |msg| %>
              <li class="mb-0.5"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="flex flex-col gap-2">
        <%= f.label :title, "Asunto", class: "text-xs font-black text-orange-500 uppercase tracking-wider" %>
        <%= f.text_field :title, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-base outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>

      <% other = @conversation.other_user(current_user) %>
      <div class="bg-white/5 border border-white/10 rounded-xl p-4">
        <h4 class="text-[11px] font-black text-orange-500 uppercase tracking-wider mb-2">Información del ticket</h4>
        <div class="text-sm text-gray-400 space-y-1">
          <div><span class="text-gray-500">Creado:</span> <%= @conversation.created_at.strftime("%d/%m/%Y %H:%M") %></div>
          <div><span class="text-gray-500">Usuario:</span> <%= other ? "#{other.first_name} #{other.last_name}" : "—" %></div>
          <div><span class="text-gray-500">Rol:</span> <%= other&.role&.humanize %></div>
          <div><span class="text-gray-500">Estado:</span> <%= @conversation.closed? ? "Cerrado" : "Abierto" %></div>
        </div>
      </div>

      <div class="flex flex-col sm:flex-row gap-3">
        <%= f.submit "Guardar cambios", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-4 px-6 rounded-xl text-sm font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] active:scale-[0.98] flex-[2]" %>
        <%= link_to "Cancelar", conversation_path(@conversation), class: "bg-white/5 text-gray-400 no-underline py-4 px-6 rounded-xl text-sm font-bold text-center border border-white/10 flex-1 transition-all duration-200 hover:text-white hover:border-orange-500/50 hover:bg-orange-500/5" %>
      </div>
    <% end %>
  </div>
</div>
