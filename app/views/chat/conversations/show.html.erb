<div class="max-w-4xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden relative flex flex-col"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05); height: calc(100vh - 200px); min-height: 300px; max-height: 700px;">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <% other = @conversation.other_user(current_user) %>

    <div class="flex items-start gap-3 p-4 lg:p-5 border-b border-white/5 shrink-0">
      <%= link_to conversations_path, class: "text-gray-500 no-underline p-2 -ml-1 rounded-lg transition-all duration-200 hover:text-orange-400 hover:bg-white/5 mt-0.5" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      <% end %>
      <div class="min-w-0 flex-1">
        <div class="font-bold text-white text-sm truncate"><%= @conversation.title %></div>
        <div class="flex items-center gap-2 mt-0.5 flex-wrap">
          <% if @conversation.pending? %>
            <span class="text-[10px] text-yellow-400 font-bold uppercase">Pendiente de asignación</span>
          <% elsif @conversation.assigned? %>
            <span class="text-[10px] text-green-400 font-bold uppercase">Atendido por: <%= @conversation.assigned_to.first_name %> <%= @conversation.assigned_to.last_name %></span>
          <% end %>
          <% if current_user.paciente? %>
            <span class="text-[10px] text-gray-500 uppercase tracking-wider">· <%= @conversation.other_user(current_user)&.role&.humanize || "Soporte" %></span>
          <% end %>
          <% if @conversation.closed? %>
            <span class="text-[10px] text-red-400 font-bold uppercase">· Cerrado</span>
          <% end %>
        </div>
      </div>
      <% if is_administrador? || is_recepcionista? %>
        <div class="flex items-center gap-2 shrink-0">
          <%= link_to edit_conversation_path(@conversation), class: "bg-white/5 text-gray-400 border border-white/10 px-3 py-1.5 rounded-lg text-[10px] font-bold no-underline transition-all duration-200 hover:text-orange-400 hover:border-orange-500/30 hover:bg-orange-500/10" do %>
            Editar
          <% end %>
          <% if !@conversation.closed? && !@conversation.pending? %>
            <%= button_to close_conversation_path(@conversation), method: :patch,
                class: "bg-white/5 text-gray-400 border border-white/10 px-3 py-1.5 rounded-lg text-[10px] font-bold cursor-pointer transition-all duration-200 hover:text-red-400 hover:border-red-500/30 hover:bg-red-500/10",
                data: { turbo_confirm: "¿Cerrar este ticket?" } do %>
              Cerrar ticket
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <div class="flex-1 overflow-y-auto p-4 lg:p-5 flex flex-col gap-3" id="messages">
      <% if @messages.any? %>
        <% @messages.each do |msg| %>
          <div id="message-<%= msg.id %>" class="flex <%= msg.user_id == current_user.id ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-[80%] lg:max-w-[65%] <%= msg.user_id == current_user.id ? 'bg-gradient-to-r from-orange-500 to-orange-600 text-black' : 'bg-white/5 text-white border border-white/10' %> rounded-2xl px-4 py-2.5 <%= msg.user_id == current_user.id ? 'rounded-br-md' : 'rounded-bl-md' %>">
              <div class="text-sm leading-relaxed break-words" style="overflow-wrap: break-word; word-wrap: break-word;"><%= msg.content %></div>
              <div class="text-[10px] mt-1 <%= msg.user_id == current_user.id ? 'text-black/60' : 'text-gray-600' %>"><%= msg.created_at.strftime("%H:%M") %></div>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="flex-1 flex items-center justify-center">
          <p class="text-gray-600 text-sm">No hay mensajes aún. Escribe algo para comenzar.</p>
        </div>
      <% end %>

      <% if @conversation.closed? && @conversation.reopen_requested? %>
        <div class="flex justify-center">
          <div class="inline-flex items-center gap-2 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-4 py-2.5">
            <svg class="w-4 h-4 text-yellow-400 shrink-0 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-xs text-yellow-300 font-semibold">
              <% if current_user.paciente? %>
                Solicitaste la reapertura de este ticket. Estamos revisando tu solicitud.
              <% else %>
                <%= @conversation.other_user(current_user)&.first_name %> solicitó la reapertura de este ticket.
              <% end %>
            </span>
          </div>
        </div>
      <% end %>

      <% if @conversation.pending? %>
        <div class="flex justify-center">
          <div class="inline-flex items-center gap-2 bg-yellow-500/10 border border-yellow-500/20 rounded-xl px-4 py-2.5">
            <svg class="w-4 h-4 text-yellow-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-xs text-yellow-300 font-semibold">
              <% if current_user.paciente? %>
                Esperando a que un operador acepte este ticket.
              <% else %>
                Este ticket está pendiente de asignación.
              <% end %>
            </span>
          </div>
        </div>
      <% end %>
    </div>

    <div class="border-t border-white/5 p-4 lg:p-5 shrink-0">
      <% if @conversation.pending? %>
        <% if current_user.paciente? %>
          <div class="text-center py-3">
            <span class="text-gray-600 text-sm">Esperando a que un operador acepte este ticket.</span>
            <%= button_to conversation_path(@conversation), method: :delete,
                class: "mt-2 bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-red-400 hover:border-red-500/30 hover:bg-red-500/10",
                data: { turbo_confirm: "¿Eliminar este ticket definitivamente?" } do %>
              Eliminar ticket
            <% end %>
          </div>
        <% elsif is_administrador? || is_recepcionista? %>
          <div class="flex items-center gap-3 justify-center">
            <span class="text-gray-600 text-sm">Este ticket está pendiente de asignación.</span>
            <%= button_to accept_conversation_path(@conversation), method: :patch,
                class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-5 py-2.5 rounded-xl text-xs font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 hover:scale-105" do %>
              Aceptar ticket
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-3">
            <span class="text-gray-600 text-sm">Este ticket está pendiente de asignación.</span>
          </div>
        <% end %>
      <% elsif @conversation.closed? %>
        <% if current_user.paciente? && @conversation.reopen_requested? %>
          <div class="text-center py-3">
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-yellow-400 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="text-yellow-400 text-sm font-semibold">Solicitud enviada — Esperando respuesta</span>
            </div>
            <%= button_to conversation_path(@conversation), method: :delete,
                class: "mt-2 bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-red-400 hover:border-red-500/30 hover:bg-red-500/10",
                data: { turbo_confirm: "¿Eliminar este ticket definitivamente?" } do %>
              Eliminar ticket
            <% end %>
          </div>
        <% elsif current_user.paciente? %>
          <div class="flex flex-col sm:flex-row items-center gap-3 justify-center">
            <span class="text-gray-600 text-sm">Este ticket está cerrado.</span>
            <%= button_to request_reopen_conversation_path(@conversation), method: :patch,
                class: "bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-green-400 hover:border-green-500/30 hover:bg-green-500/10" do %>
              Solicitar reapertura
            <% end %>
            <%= button_to conversation_path(@conversation), method: :delete,
                class: "bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-red-400 hover:border-red-500/30 hover:bg-red-500/10",
                data: { turbo_confirm: "¿Eliminar este ticket definitivamente?" } do %>
              Eliminar ticket
            <% end %>
          </div>
        <% elsif is_administrador? || is_recepcionista? %>
          <div class="flex items-center gap-3 justify-center">
            <span class="text-gray-600 text-sm">Este ticket está cerrado.</span>
            <%= button_to reopen_conversation_path(@conversation), method: :patch,
                class: "bg-white/5 text-gray-400 border border-white/10 px-4 py-2 rounded-xl text-xs font-bold cursor-pointer transition-all duration-200 hover:text-green-400 hover:border-green-500/30 hover:bg-green-500/10" do %>
              Reabrir ticket
            <% end %>
          </div>
        <% else %>
          <div class="text-center py-3">
            <span class="text-gray-600 text-sm">Este ticket está cerrado.</span>
          </div>
        <% end %>
      <% else %>
        <%= form_with url: conversation_messages_path(@conversation), scope: :message, local: true, class: "flex gap-3" do |f| %>
          <%= f.text_area :content, rows: 1, required: true, placeholder: "Escribe un mensaje...", 
              class: "flex-1 p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600 resize-none",
              oninput: "this.style.height = ''; this.style.height = (this.scrollHeight) + 'px'",
              onkeydown: "if(event.key === 'Enter' && !event.shiftKey) { event.preventDefault(); this.form.requestSubmit() }" %>
          <%= f.button class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none p-3 rounded-xl cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 shrink-0 self-end" do %>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 19V5m0 0l-7 7m7-7l7 7"/></svg>
          <% end %>
        <% end %>
      <% end %>
    </div>
  </div>

</div>
