<div class="max-w-6xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 mb-8 lg:mb-10 flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div>
      <h1 class="text-3xl lg:text-4xl font-black text-white m-0 tracking-tight leading-tight">Consola para Administradores</h1>
      <p class="text-gray-400 text-base mt-2 font-medium">
        Bienvenido <%= current_user&.role %> 
        <span class="text-orange-500 font-bold"><%= current_user&.first_name %> <%= current_user&.last_name %></span>
      </p>
    </div>
    <% if is_administrador? %>
    <%= link_to new_admin_user_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 lg:px-7 py-3.5 rounded-xl text-sm font-bold inline-flex items-center gap-2.5 shrink-0 shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nuevo usuario
    <% end %>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-8">

    <% if is_administrador? || is_recepcionista? %>
    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="flex justify-between items-start mb-6">
        <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center shadow-lg shadow-orange-500/20">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <span class="bg-gradient-to-r from-orange-500 to-orange-600 text-black text-[10px] font-black px-3 py-1.5 rounded-full tracking-wider uppercase shadow-lg shadow-orange-500/20">Top Sedes</span>
      </div>
      <h2 class="text-xl font-black text-white m-0 tracking-tight">Sedes con mayor afluencia</h2>
      <p class="text-gray-500 text-sm mt-2 mb-6 leading-relaxed">Optimización de recursos basada en volumen de pacientes.</p>
      <% @top_branches.each do |branch| %>
        <div class="flex items-center justify-between bg-gradient-to-r from-orange-500 to-orange-600 p-3 lg:p-3.5 rounded-xl mb-2.5 shadow-lg shadow-orange-500/10">
          <span class="text-black text-sm font-semibold"><%= branch.name %></span>
          <span class="text-black text-base font-black"><%= branch.user_count %></span>
        </div>
      <% end %>
    </div>
    <% end %>

    <% if is_administrador? %>
    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </div>
      <h2 class="text-xl lg:text-2xl font-black text-white m-0">Personal</h2>
      <p class="text-gray-400 text-sm mt-2.5 leading-relaxed">Control total de usuarios, roles médicos y permisos de acceso al sistema.</p>
      <div class="mt-6 p-4 bg-gradient-to-r from-orange-500 to-orange-600 rounded-xl flex items-center gap-4 shadow-lg shadow-orange-500/20">
        <span class="text-2xl font-black text-black"><%= @total_users %></span>
        <span class="text-xs font-bold text-black uppercase tracking-wider">Usuarios activos</span>
      </div>
      <%= link_to admin_users_path, class: "mt-6 lg:mt-8 block text-center no-underline py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
        Administrar Personal →
      <% end %>
    </div>
    <% end %>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-7h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h2 class="text-xl lg:text-2xl font-black text-white m-0">Sedes</h2>
      <p class="text-gray-400 text-sm mt-2.5 leading-relaxed">Gestión de ubicaciones físicas, consultorios disponibles y horarios de atención.</p>
      <div class="mt-6 p-4 bg-gradient-to-r from-orange-500 to-orange-600 rounded-xl flex items-center gap-4 shadow-lg shadow-orange-500/20">
        <span class="text-2xl font-black text-black"><%= Branch.count %></span>
        <span class="text-xs font-bold text-black uppercase tracking-wider">Sucursales en total</span>
      </div>
      <%= link_to admin_branches_path, class: "mt-6 lg:mt-8 block text-center no-underline py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
        Ver Sedes →
      <% end %>
    </div>

    <% if is_administrador? %>
    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="flex justify-between items-start mb-4">
        <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center shadow-lg shadow-orange-500/20">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
        </div>
        <span class="bg-gradient-to-r from-orange-500 to-orange-600 text-black text-[10px] font-black px-3 py-1.5 rounded-full tracking-wider uppercase shadow-lg shadow-orange-500/20 shrink-0">Tiempo real</span>
      </div>
      <h2 class="text-xl font-black text-white m-0 tracking-tight">Actividad del Sistema</h2>
      <p class="text-gray-500 text-sm mt-1 mb-5 leading-relaxed">Últimas acciones registradas en la plataforma.</p>

      <% if @recent_activities.any? %>
        <div class="flex flex-col gap-1.5 mb-5">
          <% @recent_activities.each do |entry| %>
            <div class="flex items-start gap-2.5 py-2 px-2.5 rounded-lg transition-colors hover:bg-white/[0.03]">
              <div class="w-1.5 h-1.5 rounded-full bg-orange-500/60 mt-2 shrink-0"></div>
              <div class="flex-1 min-w-0">
                <p class="m-0 text-sm text-gray-300 truncate"><%= entry["description"] || entry["action"]&.humanize %></p>
                <div class="flex items-center gap-2 mt-0.5 text-[10px] text-gray-600">
                  <span class="font-semibold text-gray-500"><%= entry["user_name"] %></span>
                  <span>&middot;</span>
                  <span><%= time_ago_in_words(Time.parse(entry["visited_at"])) %></span>
                  <span>&middot;</span>
                  <span><%= entry["method"] %></span>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%= link_to admin_activities_path, class: "block text-center no-underline py-3.5 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
          Ver toda la actividad →
        <% end %>
      <% else %>
        <div class="text-center py-10 border border-dashed border-white/10 rounded-xl">
          <p class="text-gray-500 text-sm m-0">No hay actividad registrada todavía.</p>
        </div>
        <%= link_to admin_activities_path, class: "mt-4 block text-center no-underline py-3 bg-white/5 text-gray-400 rounded-xl text-sm font-bold transition-all duration-200 hover:text-orange-400 hover:bg-white/[0.07]" do %>
          Ir al registro de actividad →
        <% end %>
      <% end %>
    </div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      </div>
      <h2 class="text-xl lg:text-2xl font-black text-white m-0">Hero Slides</h2>
      <p class="text-gray-400 text-sm mt-2.5 leading-relaxed">Gestioná los slides del carrusel principal de la página de inicio.</p>
      <%= link_to admin_hero_slides_path, class: "mt-6 lg:mt-8 block text-center no-underline py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
        Administrar Slides →
      <% end %>
    </div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <h2 class="text-xl lg:text-2xl font-black text-white m-0">Pasos del Proceso</h2>
      <p class="text-gray-400 text-sm mt-2.5 leading-relaxed">Administrá los pasos del servicio que se muestran en la página principal.</p>
      <%= link_to admin_process_steps_path, class: "mt-6 lg:mt-8 block text-center no-underline py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
        Administrar Pasos →
      <% end %>
    </div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
         style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="w-14 h-14 bg-gradient-to-br from-orange-500 to-orange-600 text-black rounded-xl flex items-center justify-center mb-6 shadow-lg shadow-orange-500/20">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
      </div>
      <h2 class="text-xl lg:text-2xl font-black text-white m-0">Testimonios</h2>
      <p class="text-gray-400 text-sm mt-2.5 leading-relaxed">Gestioná los testimonios de pacientes y atletas en la página de inicio.</p>
      <%= link_to admin_testimonials_path, class: "mt-6 lg:mt-8 block text-center no-underline py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black rounded-xl text-sm font-bold uppercase tracking-wider shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02]" do %>
        Administrar Testimonios →
      <% end %>
    </div>
    <% end %>

  </div>
</div>
