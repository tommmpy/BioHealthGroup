<div class="max-w-6xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">
  <div class="flex justify-between items-center gap-4 mb-8 lg:mb-10">
    <h1 class="text-2xl lg:text-3xl font-black text-white tracking-tight m-0">Slides del Hero</h1>
    <%= link_to new_admin_hero_slide_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-bold inline-flex items-center gap-2 shrink-0 shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nuevo Slide
    <% end %>
  </div>

  <div class="grid grid-cols-1 gap-5 lg:gap-6">
    <% @hero_slides.each do |slide| %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-orange-500/20"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="p-5 lg:p-6 relative">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="text-[10px] font-black text-gray-500 uppercase tracking-wider">Orden <%= slide.sort_order %></span>
                <% if slide.active %>
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                <% else %>
                  <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                <% end %>
              </div>
              <h2 class="text-xl font-bold text-white m-0"><%= slide.title %></h2>
              <% if slide.subtitle.present? %>
                <p class="text-gray-400 text-sm mt-1"><%= slide.subtitle %></p>
              <% end %>
              <% if slide.image.attached? %>
                <div class="mt-3 w-32 h-20 rounded-lg overflow-hidden border border-white/10">
                  <%= image_tag slide.image, class: "w-full h-full object-cover" %>
                </div>
              <% end %>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <%= link_to edit_admin_hero_slide_path(slide), class: "bg-white/5 border border-white/10 text-gray-300 no-underline p-2.5 rounded-xl transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to admin_hero_slide_path(slide), method: :delete, class: "bg-white/5 border border-white/10 text-gray-300 p-2.5 rounded-xl transition-all duration-200 hover:border-red-500/50 hover:text-red-400 cursor-pointer",
                  data: { turbo_confirm: "¿Eliminar este slide?" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>
          <% if slide.cta_text.present? %>
            <div class="mt-3 inline-block bg-gradient-to-r from-orange-500 to-orange-600 text-black text-[10px] font-black px-3 py-1.5 rounded-lg uppercase tracking-wider">
              <%= slide.cta_text %> → <%= slide.cta_link || "/" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <% if @hero_slides.empty? %>
      <div class="py-24 text-center bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl border-2 border-dashed border-orange-500/30">
        <p class="text-gray-500 font-semibold">No hay slides todavía.</p>
        <%= link_to "Crear primer slide", new_admin_hero_slide_path, class: "text-orange-500 font-bold no-underline transition-colors hover:text-orange-400" %>
      </div>
    <% end %>
  </div>
</div>
