<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-4xl relative animate-fade-up">
    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative transition-all duration-300"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="px-5 sm:px-7 pt-5 sm:pt-7 pb-2">
        <div class="flex items-center gap-4 pb-4 mb-2 border-b border-white/5">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 shrink-0">
            <svg class="w-5.5 h-5.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <div>
            <h1 class="text-lg sm:text-xl font-black text-white tracking-tight"><%= @testimonial.author_name %></h1>
            <p class="text-gray-500 text-xs sm:text-sm mt-0.5">Testimonio</p>
          </div>
        </div>
      </div>

      <div class="px-5 sm:px-7 pb-5 sm:pb-7 flex flex-col gap-4">
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="sm:col-span-2">
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Contenido</span>
              <p class="text-white text-sm font-semibold leading-relaxed"><%= @testimonial.content %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Rol del autor</span>
              <p class="text-white text-sm font-semibold"><%= @testimonial.author_role.presence || "&mdash;" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Orden</span>
              <p class="text-white text-sm font-semibold"><%= @testimonial.sort_order %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Estado</span>
              <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-bold uppercase <%= @testimonial.active ? "text-green-400 bg-green-500/10 border border-green-500/20" : "text-red-400 bg-red-500/10 border border-red-500/20" %>">
                <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                <%= @testimonial.active ? "Activo" : "Inactivo" %>
              </span>
            </div>
          </div>
        </div>

        <% if @testimonial.avatar.attached? %>
          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
            <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-2">Avatar</span>
            <div class="w-32 h-32 rounded-full overflow-hidden border border-white/10">
              <%= image_tag @testimonial.avatar, class: "w-full h-full object-cover" %>
            </div>
          </div>
        <% end %>

        <div class="flex items-center gap-3 pt-2">
          <%= link_to edit_admin_testimonial_path(@testimonial), class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-bold inline-flex items-center gap-2 shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Editar
          <% end %>
          <%= link_to admin_testimonials_path, class: "text-gray-400 no-underline text-sm font-bold px-4 py-3 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5 inline-flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Volver
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
