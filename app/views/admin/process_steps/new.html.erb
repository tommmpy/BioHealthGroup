<div class="max-w-3xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">
  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/20">
        <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      </div>
      <h1 class="text-2xl font-black text-white m-0">Nuevo Paso</h1>
    </div>

    <%= form_with model: [:admin, @process_step], local: true, class: "flex flex-col gap-5" do |f| %>
      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :step_number, "Número de paso", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
          <%= f.number_field :step_number, required: true, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
        </div>
        <div>
          <%= f.label :active, class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
          <label class="flex items-center gap-3 cursor-pointer pt-2">
            <%= f.check_box :active, checked: @process_step.active != false, class: "w-5 h-5 rounded border-white/10 bg-white/5 text-orange-500 focus:ring-orange-500" %>
            <span class="text-white text-sm">Activo</span>
          </label>
        </div>
      </div>

      <div>
        <%= f.label :title, "Título", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_field :title, required: true, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>

      <div>
        <%= f.label :description, "Descripción", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_area :description, rows: 3, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600 resize-none" %>
      </div>

      <div>
        <%= f.label :image, "Imagen", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.file_field :image, accept: "image/*", class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-bold file:bg-gradient-to-r file:from-orange-500 file:to-orange-600 file:text-black cursor-pointer" %>
      </div>

      <div>
        <%= f.label :icon, "Icono (nombre del archivo SVG en assets)", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_field :icon, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>

      <div class="flex items-center gap-3 pt-4 border-t border-white/5">
        <%= f.submit "Guardar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-8 py-3.5 rounded-xl text-sm font-bold cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" %>
        <%= link_to "Cancelar", admin_process_steps_path, class: "text-gray-400 no-underline text-sm font-bold px-4 py-3.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" %>
      </div>
    <% end %>
  </div>
</div>
