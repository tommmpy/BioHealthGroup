<div class="max-w-6xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">
  <div class="flex justify-between items-center gap-4 mb-8 lg:mb-10">
    <h1 class="text-2xl lg:text-3xl font-black text-white tracking-tight m-0">Pasos del Proceso</h1>
    <%= link_to new_admin_process_step_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-bold inline-flex items-center gap-2 shrink-0 shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nuevo Paso
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 lg:gap-6">
    <% @process_steps.each do |step| %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden transition-all duration-300 hover:border-orange-500/20"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="p-5 lg:p-6 relative">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0 flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 text-black text-sm font-black flex items-center justify-center shadow-lg shadow-orange-500/20"><%= step.step_number %></span>
                <% if step.active %>
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                <% else %>
                  <span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
                <% end %>
              </div>
              <h2 class="text-xl font-bold text-white m-0"><%= step.title %></h2>
              <% if step.description.present? %>
                <p class="text-gray-400 text-sm mt-1 line-clamp-2"><%= step.description %></p>
              <% end %>
              <% if step.icon.present? %>
                <span class="inline-block mt-2 text-[10px] font-bold text-orange-500 uppercase tracking-wider">Icono: <%= step.icon %></span>
              <% end %>
            </div>
            <div class="flex items-center gap-2 shrink-0">
              <%= link_to edit_admin_process_step_path(step), class: "bg-white/5 border border-white/10 text-gray-300 no-underline p-2.5 rounded-xl transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to admin_process_step_path(step), method: :delete, class: "bg-white/5 border border-white/10 text-gray-300 p-2.5 rounded-xl transition-all duration-200 hover:border-red-500/50 hover:text-red-400 cursor-pointer",
                  data: { turbo_confirm: "¿Eliminar este paso?" } do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    <% end %>

    <% if @process_steps.empty? %>
      <div class="col-span-1 md:col-span-2 py-24 text-center bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl border-2 border-dashed border-orange-500/30">
        <p class="text-gray-500 font-semibold">No hay pasos todavía.</p>
        <%= link_to "Crear primer paso", new_admin_process_step_path, class: "text-orange-500 font-bold no-underline transition-colors hover:text-orange-400" %>
      </div>
    <% end %>
  </div>
</div>
