<div class="max-w-3xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">
  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <div class="flex items-center gap-3 mb-8">
      <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/20">
        <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h1 class="text-2xl font-black text-white m-0">Nueva Sede</h1>
    </div>

    <%= form_with model: [:admin, @branch], local: true, class: "flex flex-col gap-5" do |f| %>
      <div>
        <%= f.label :name, "Nombre de la sede", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_field :name, required: true, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>

      <div>
        <%= f.label :address, "Dirección", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_field :address, required: true, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>

      <div>
        <%= f.label :phone, "Teléfono", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <%= f.text_field :phone, required: true, class: "w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>

      <div>
        <%= f.label :active, class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
        <label class="flex items-center gap-3 cursor-pointer pt-2">
          <%= f.check_box :enabled, checked: @branch.enabled != false, class: "w-5 h-5 rounded border-white/10 bg-white/5 text-orange-500 focus:ring-orange-500" %>
          <span class="text-white text-sm">Sede habilitada</span>
        </label>
      </div>

      <div class="flex items-center gap-3 pt-4 border-t border-white/5">
        <%= f.submit "Guardar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-8 py-3.5 rounded-xl text-sm font-bold cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" %>
        <%= link_to "Cancelar", admin_branches_path, class: "text-gray-400 no-underline text-sm font-bold px-4 py-3.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" %>
      </div>
    <% end %>
  </div>
</div>
