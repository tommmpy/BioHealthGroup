<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-4xl relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative transition-all duration-300"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="px-5 sm:px-7 pt-5 sm:pt-7 pb-2">
        <div class="flex items-center gap-4 pb-4 mb-2 border-b border-white/5">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 shrink-0">
            <svg class="w-5.5 h-5.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg sm:text-xl font-black text-white tracking-tight"><%= @branch.name %></h1>
            <p class="text-gray-500 text-xs sm:text-sm mt-0.5">Detalles de la sede</p>
          </div>
        </div>
      </div>

      <div class="px-5 sm:px-7 pb-5 sm:pb-7 flex flex-col gap-4">
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
          <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
            </div>
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Información de la Sede</h2>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Dirección</span>
              <p class="text-white text-sm font-semibold"><%= @branch.address.presence || "—" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Teléfono</span>
              <p class="text-white text-sm font-semibold"><%= @branch.phone.presence || "—" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Estado</span>
              <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded text-xs font-bold uppercase <%= @branch.enabled ? "text-green-400 bg-green-500/10 border border-green-500/20" : "text-red-400 bg-red-500/10 border border-red-500/20" %>">
                <span class="w-1.5 h-1.5 rounded-full bg-current"></span>
                <%= @branch.enabled ? "Abierta" : "Cerrada" %>
              </span>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Usuarios asignados</span>
              <p class="text-white text-sm font-semibold"><%= @branch.users.count %></p>
            </div>
          </div>
        </div>

        <div class="flex items-center gap-3 pt-2">
          <%= link_to admin_branches_path, class: "text-gray-400 no-underline text-sm font-bold px-4 py-3 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5 inline-flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Volver a sedes
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
