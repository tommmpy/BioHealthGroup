<% status_config = {
  "pending" => { label: "Pendiente", color: "text-yellow-400", bg: "bg-yellow-500/10", border: "border-yellow-500/20", icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
  "in_progress" => { label: "En producción", color: "text-blue-400", bg: "bg-blue-500/10", border: "border-blue-500/20", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
  "completed" => { label: "Completada", color: "text-green-400", bg: "bg-green-500/10", border: "border-green-500/20", icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
  "cancelled" => { label: "Cancelada", color: "text-red-400", bg: "bg-red-500/10", border: "border-red-500/20", icon: "M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" }
} %>

<div class="px-4 mt-8 lg:mt-12 animate-fade-up">

  <div class="max-w-7xl mx-auto bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 lg:mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0">Órdenes de Producción</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @production_orders.count %> ÓRDENES
      </div>
    </div>
  </div>

  <div x-data="{ advancedOpen: false }" class="max-w-7xl mx-auto mb-5">
    <button @click="advancedOpen = !advancedOpen" class="flex items-center gap-2 text-gray-400 text-sm font-semibold transition-colors duration-200 hover:text-orange-400 bg-transparent border-none cursor-pointer">
      <svg class="w-4 h-4" :class="{ 'rotate-180': advancedOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4"/></svg>
      Búsqueda avanzada
      <% if params[:q].present? %>
        <span class="bg-orange-500/10 text-orange-400 text-[10px] font-bold px-2 py-0.5 rounded-full">activo</span>
      <% end %>
    </button>
    <div x-show="advancedOpen"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         class="mt-3">
      <%= search_form_for @q, url: admin_production_orders_path, method: :get, local: true, class: "bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-5 relative",
          style: "box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);" do |f| %>
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Estado</label>
            <%= f.select :status_eq, options_for_select(ProductionOrder.statuses.keys.map { |k| [k.humanize, k] }, params.dig(:q, :status_eq)), { include_blank: "Todos" }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Asignado a</label>
            <%= f.collection_select :assigned_to_id_eq, User.where(role: User.roles[:operario]), :id, ->(u) { "#{u.first_name} #{u.last_name}" }, { include_blank: "Todos", selected: params.dig(:q, :assigned_to_id_eq) }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha desde</label>
            <%= f.date_field :created_at_gteq, value: params.dig(:q, :created_at_gteq), class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha hasta</label>
            <%= f.date_field :created_at_lteq, value: params.dig(:q, :created_at_lteq), class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
        </div>
        <div class="flex items-center gap-3 pt-2 border-t border-white/5">
          <%= f.submit "Filtrar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-6 py-2.5 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 hover:scale-105" %>
          <%= link_to admin_production_orders_path, class: "text-gray-400 no-underline text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" do %>
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            Limpiar
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="max-w-7xl mx-auto flex flex-col gap-4">
    <% if @production_orders.any? %>
      <% @production_orders.each do |order| %>
        <% sc = status_config[order.status] || status_config.values.first %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative transition-all duration-300 hover:border-orange-500/20"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <div class="flex flex-col lg:flex-row lg:items-center gap-4 lg:gap-6">
            <div class="flex items-start gap-4 flex-1 min-w-0">
              <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/20 shrink-0">
                <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
              </div>
              <div class="min-w-0">
                <div class="flex items-center gap-3 flex-wrap">
                  <h3 class="text-lg font-black text-white m-0">Orden #<%= order.id %></h3>
                  <span class="<%= sc[:bg] %> <%= sc[:color] %> <%= sc[:border] %> text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border leading-tight">
                    <svg class="w-3 h-3 inline mr-1 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= sc[:icon] %>"/></svg>
                    <%= sc[:label] %>
                  </span>
                </div>
                <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm">
                  <span class="text-gray-400">
                    <span class="text-gray-600">Estudio:</span>
                    <%= link_to order.estudio.nombre_completo, admin_estudio_path(order.estudio), class: "text-white no-underline hover:text-orange-400 transition-colors" %>
                  </span>
                  <% if order.assigned_to.present? %>
                    <span class="text-gray-400">
                      <span class="text-gray-600">Operario:</span>
                      <span class="text-white"><%= order.assigned_to.name %></span>
                    </span>
                  <% end %>
                  <span class="text-gray-500">
                    <span class="text-gray-600">Creada:</span>
                    <%= l(order.created_at.to_date, format: :default) %>
                  </span>
                  <% if order.due_date.present? %>
                    <span class="<%= order.due_date < Date.current && !order.completed? ? 'text-red-400' : 'text-gray-500' %>">
                      <span class="text-gray-600">Vence:</span>
                      <%= l(order.due_date, format: :default) %>
                    </span>
                  <% end %>
                </div>
                <% if order.notes.present? %>
                  <p class="text-gray-500 text-sm mt-2 mb-0 line-clamp-2"><%= order.notes %></p>
                <% end %>
              </div>
            </div>

            <div class="flex items-center gap-2 shrink-0">
              <% if order.pending? && (is_administrador? || is_operario?) %>
                <%= button_to "Iniciar producción", start_admin_production_order_path(order), method: :patch,
                    form: { data: { turbo_confirm: "¿Desea iniciar esta orden de producción?" } },
                    class: "bg-gradient-to-r from-blue-500 to-blue-600 text-white border-none px-4 py-2.5 rounded-lg text-[11px] font-bold cursor-pointer shadow-lg shadow-blue-500/20 transition-all duration-200 hover:shadow-blue-500/30 hover:scale-105 whitespace-nowrap" %>
              <% end %>
              <% if order.in_progress? && (is_administrador? || is_operario?) %>
                <%= button_to "Completar", complete_admin_production_order_path(order), method: :patch,
                    form: { data: { turbo_confirm: "¿Confirma que la producción ha finalizado?" } },
                    class: "bg-gradient-to-r from-green-500 to-green-600 text-black border-none px-4 py-2.5 rounded-lg text-[11px] font-bold cursor-pointer shadow-lg shadow-green-500/20 transition-all duration-200 hover:shadow-green-500/30 hover:scale-105 whitespace-nowrap" %>
              <% end %>
              <%= link_to "Detalle", admin_production_order_path(order),
                  class: "border border-white/10 text-gray-400 no-underline px-4 py-2.5 rounded-lg text-[11px] font-bold text-center transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400 hover:bg-orange-500/5" %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-10 text-center relative"
           style="box-shadow: 0 0 20px rgba(255,107,0,0.02), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
        <p class="text-gray-500 font-semibold">No hay órdenes de producción.</p>
        <p class="text-gray-600 text-sm mt-1">Las órdenes se generan automáticamente al finalizar un estudio.</p>
      </div>
    <% end %>
  </div>
</div>
