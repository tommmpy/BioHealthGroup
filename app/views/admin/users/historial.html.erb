<div class="max-w-5xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-8">
    <div>
      <%= link_to admin_user_path(@user), class: "text-gray-500 no-underline text-sm flex items-center gap-1 mb-3 transition-colors duration-200 hover:text-orange-400" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
        Volver al perfil
      <% end %>
      <h1 class="text-3xl lg:text-4xl font-black m-0 tracking-tight">Historial Clínico</h1>
      <p class="text-gray-500 mt-1 text-sm"><%= "#{@user.first_name} #{@user.last_name}" %> · <%= @user.ci %></p>
    </div>
    <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-5 py-3 rounded-xl font-black text-sm shadow-lg shadow-orange-500/20 whitespace-nowrap">
      <%= @estudios.count %> ESTUDIOS
    </div>
  </div>

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-8 relative mb-6"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

    <div class="flex items-center gap-2.5 mb-6 pb-4 border-b border-white/5">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
        <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
      </div>
      <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider m-0">Resumen de Actividad</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="bg-white/5 border border-white/5 rounded-xl p-4 text-center">
        <span class="block text-3xl font-black text-orange-400"><%= @estudios.count %></span>
        <span class="text-gray-500 text-xs uppercase tracking-wider font-bold">Estudios totales</span>
      </div>
      <div class="bg-white/5 border border-white/5 rounded-xl p-4 text-center">
        <span class="block text-3xl font-black text-green-400"><%= @estudios.select(&:finalizado?).count %></span>
        <span class="text-gray-500 text-xs uppercase tracking-wider font-bold">Finalizados</span>
      </div>
      <div class="bg-white/5 border border-white/5 rounded-xl p-4 text-center">
        <span class="block text-3xl font-black text-yellow-400"><%= @estudios.select(&:pendiente?).count %></span>
        <span class="text-gray-500 text-xs uppercase tracking-wider font-bold">Pendientes</span>
      </div>
    </div>
  </div>

  <div class="flex flex-col gap-3">
    <% if @estudios.any? %>
      <% @estudios.each do |estudio| %>
        <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 lg:p-6 relative transition-all duration-200 hover:border-orange-500/20"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
          <div class="flex flex-col sm:flex-row sm:items-start gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-3 flex-wrap mb-2">
                <span class="font-bold text-white text-lg"><%= estudio.nombre_completo %></span>
                <%
                  badge_color = case estudio.estado
                  when "pendiente" then "bg-yellow-500/10 text-yellow-400 border-yellow-500/20"
                  when "en_progreso" then "bg-blue-500/10 text-blue-400 border-blue-500/20"
                  when "finalizado" then "bg-green-500/10 text-green-400 border-green-500/20"
                  end
                %>
                <span class="<%= badge_color %> text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border leading-tight"><%= estudio.estado.humanize %></span>
              </div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-1.5 text-sm text-gray-500">
                <span><%= estudio.fecha_estudio.strftime("%d/%m/%Y %H:%M") %></span>
                <span class="text-gray-700">·</span>
                <span><%= estudio.branch&.name || "Sin sede" %></span>
                <% if estudio.medico.present? %>
                  <span class="text-gray-700">·</span>
                  <span>Dr. <%= estudio.medico.first_name %> <%= estudio.medico.last_name %></span>
                <% end %>
              </div>
              <% if Array(estudio.tipo_producto).any? %>
                <div class="mt-3 flex flex-wrap gap-1.5">
                  <% Array(estudio.tipo_producto).each do |prod| %>
                    <span class="bg-white/5 text-gray-400 border border-white/10 px-2.5 py-0.5 rounded-full text-[11px]"><%= prod %></span>
                  <% end %>
                </div>
              <% end %>
            </div>
            <div class="shrink-0">
              <%= link_to admin_estudio_path(estudio), class: "border border-white/10 text-gray-400 no-underline px-4 py-2 rounded-lg text-[11px] font-bold text-center transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400 hover:bg-orange-500/5 inline-flex items-center gap-1.5" do %>
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                Ver detalle
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-16 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-gray-500 font-semibold">Este paciente no tiene estudios registrados.</p>
        <%= link_to "Agendar estudio", new_admin_estudio_path(user_id: @user.id), class: "inline-block mt-3 bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 py-2.5 rounded-xl text-sm font-black shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" %>
      </div>
    <% end %>
  </div>
</div>
