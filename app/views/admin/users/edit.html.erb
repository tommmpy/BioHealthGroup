<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-4xl relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="px-5 sm:px-7 pt-5 sm:pt-7 pb-2">
        <div class="flex items-center gap-4 pb-4 mb-2 border-b border-white/5">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 shrink-0">
            <svg class="w-5.5 h-5.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg sm:text-xl font-black text-white tracking-tight">Editar Usuario</h1>
            <p class="text-gray-500 text-xs sm:text-sm mt-0.5">Modificando los datos de: <strong class="text-orange-500"><%= "#{@user.first_name} #{@user.last_name}" %></strong></p>
          </div>
        </div>
      </div>

      <%= form_with model: @user, url: admin_user_path(@user), method: :patch do |f| %>
        <% if @user.errors.any? %>
          <div class="mx-5 sm:mx-7 mb-4 bg-red-950/80 backdrop-blur border border-red-500/20 p-3 rounded-xl">
            <p class="text-red-400 text-xs font-bold mb-1">Errores al actualizar el usuario:</p>
            <ul class="m-0 pl-4 text-gray-300 text-xs">
              <% @user.errors.full_messages.each do |msg| %>
                <li class="mb-0.5"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="px-5 sm:px-7 pb-5 sm:pb-7 flex flex-col gap-4"
             x-data="{
               type: '<%= @user.user_type || "persona" %>',
               birthday: '<%= @user.birthday || "" %>',
               typeOpen: false,
               typeIdx: -1,
               roleOpen: false,
               roleIdx: -1,
               roleSel: '<%= @user.role %>',
               branchOpen: false,
               branchIdx: -1,
               branchSel: '<%= @user.branch_id %>',
               get typeOptions() {
                 return <%= User.user_types.keys.map { |t| { value: t.to_s, label: t.to_s.humanize } }.to_json %>;
               },
               get roleOptions() {
                 return <%= User::ROLE_HUMANIZED.map { |key, human| { value: key.to_s, label: human } }.to_json %>;
               },
               get branchOptions() {
                 return <%= Branch.all.order(:name).map { |b| { id: b.id, name: b.name } }.to_json %>;
               },
               closeAll() { this.typeOpen = false; this.roleOpen = false; this.branchOpen = false },
               typeToggle() { this.closeAll(); this.typeOpen = !this.typeOpen },
               typePick(v) { this.type = v.value; this.typeOpen = false; this.typeIdx = -1 },
               roleToggle() { this.closeAll(); this.roleOpen = !this.roleOpen },
               rolePick(v) { this.roleSel = v.value; this.roleOpen = false; this.roleIdx = -1 },
               branchToggle() { this.closeAll(); this.branchOpen = !this.branchOpen },
               branchPick(b) { this.branchSel = b.id; this.branchOpen = false; this.branchIdx = -1 },
               get edad() {
                 if (!this.birthday) return null;
                 const p = this.birthday.split('-');
                 if (p.length !== 3) return null;
                 const b = new Date(+p[0], +p[1] - 1, +p[2]);
                 const t = new Date();
                 let a = t.getFullYear() - b.getFullYear();
                 const m = t.getMonth() - b.getMonth();
                 if (m < 0 || (m === 0 && t.getDate() < b.getDate())) a--;
                 return a;
               },
               get requiereContacto() {
                 return this.type === 'empresa' || (this.type === 'persona' && (!this.birthday || this.edad < 18));
               },
               get contactoLabel() {
                 if (this.type === 'empresa') return 'Contacto de empresa';
                 return 'Contacto de Madre, Padre o Tutor';
               },
               get contactoPlaceholder() {
                 if (this.type === 'empresa') return 'Nombre y teléfono de la empresa';
                 return 'Nombre y teléfono del tutor';
               }
             }"
             @keydown.escape="closeAll()">

          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
              <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                </svg>
              </div>
              <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Información Personal</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-3.5">
              <div>
                <%= f.label :first_name, "Nombres", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  </div>
                  <%= f.text_field :first_name, placeholder: "Ej: Carlos", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div>
                <%= f.label :last_name, "Apellidos", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                  </div>
                  <%= f.text_field :last_name, placeholder: "Ej: Gómez", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div>
                <%= f.label :ci, "Cédula de Identidad", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.5.835 2.5 2.5M7 16c-.678 0-1.306.183-1.854.5M15 11a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.418.835 3 2"/></svg>
                  </div>
                  <%= f.text_field :ci, placeholder: "1.234.567-8", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div>
                <%= f.label :phone_number, "Teléfono", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                  </div>
                  <%= f.telephone_field :phone_number, placeholder: "099 000 000", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div>
                <%= f.label :email_address, "Correo electrónico", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                  </div>
                  <%= f.email_field :email_address, placeholder: "email@ejemplo.com", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div>
                <%= f.label :birthday, "Fecha de nacimiento", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  </div>
                  <%= f.date_field :birthday, class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]", max: Date.current.iso8601, "x-model": "birthday" %>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
              <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Configuración de Cuenta</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-3.5">
              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5">Tipo de usuario</label>
                <%= f.hidden_field :user_type, "x-model": "type" %>
                <div class="relative" @click.away="typeOpen = false">
                  <div @click="typeToggle()"
                       class="w-full pl-8 p-2.5 border border-white/10 rounded-lg bg-white/5 text-sm text-white cursor-pointer flex items-center justify-between gap-2 transition-all duration-200 hover:border-white/20 relative"
                       :class="{ 'border-orange-500/50 shadow-[0_0_12px_rgba(255,107,0,0.08)]': typeOpen }">
                    <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                      <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
                    </div>
                    <span class="text-gray-500 text-sm" x-show="!type">Seleccionar...</span>
                    <span class="truncate font-semibold text-sm ml-auto" x-show="type" x-text="typeOptions.find(o => o.value === type)?.label"></span>
                    <svg class="w-3.5 h-3.5 text-gray-500 shrink-0 transition-transform duration-200" :class="{ 'rotate-180': typeOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 9l6 6 6-6"/></svg>
                  </div>
                  <div x-show="typeOpen"
                       x-transition:enter="transition ease-out duration-150"
                       x-transition:enter-start="opacity-0 -translate-y-1"
                       x-transition:enter-end="opacity-100 translate-y-0"
                       class="absolute z-50 top-full left-0 right-0 mt-1 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-hidden shadow-2xl">
                    <template x-for="(opt, i) in typeOptions" :key="opt.value">
                      <div @click="typePick(opt)"
                           @mouseenter="typeIdx = i" @mouseleave="typeIdx = -1"
                           :class="{ 'bg-white/[0.07]': typeIdx === i, 'text-orange-400': opt.value === type }"
                           class="px-3 py-2.5 cursor-pointer border-b border-white/5 transition-colors duration-100 last:border-0 text-sm font-semibold"
                           x-text="opt.label">
                      </div>
                    </template>
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5">Rol asignado</label>
                <input type="hidden" name="user[role]" x-model="roleSel" />
                <div class="relative" @click.away="roleOpen = false">
                  <div @click="roleToggle()"
                       class="w-full pl-8 p-2.5 border border-white/10 rounded-lg bg-white/5 text-sm text-white cursor-pointer flex items-center justify-between gap-2 transition-all duration-200 hover:border-white/20 relative"
                       :class="{ 'border-orange-500/50 shadow-[0_0_12px_rgba(255,107,0,0.08)]': roleOpen }">
                    <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                      <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                    </div>
                    <span x-show="!roleSel" class="text-gray-500 text-sm">Seleccionar...</span>
                    <span x-show="roleSel" class="truncate font-semibold text-sm ml-auto" x-text="roleOptions.find(o => o.value === roleSel)?.label"></span>
                    <svg class="w-3.5 h-3.5 text-gray-500 shrink-0 transition-transform duration-200" :class="{ 'rotate-180': roleOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 9l6 6 6-6"/></svg>
                  </div>
                  <div x-show="roleOpen"
                       x-transition:enter="transition ease-out duration-150"
                       x-transition:enter-start="opacity-0 -translate-y-1"
                       x-transition:enter-end="opacity-100 translate-y-0"
                       class="absolute z-50 top-full left-0 right-0 mt-1 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-y-auto max-h-60 shadow-2xl">
                    <template x-for="(opt, i) in roleOptions" :key="opt.value">
                      <div @click="rolePick(opt)"
                           @mouseenter="roleIdx = i" @mouseleave="roleIdx = -1"
                           :class="{ 'bg-white/[0.07]': roleIdx === i, 'text-orange-400': opt.value === roleSel }"
                           class="px-3 py-2.5 cursor-pointer border-b border-white/5 transition-colors duration-100 last:border-0 text-sm font-semibold"
                           x-text="opt.label">
                      </div>
                    </template>
                  </div>
                </div>
              </div>

              <div>
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5">Sucursal</label>
                <input type="hidden" name="user[branch_id]" x-model="branchSel" />
                <div class="relative" @click.away="branchOpen = false">
                  <div @click="branchToggle()"
                       class="w-full pl-8 p-2.5 border border-white/10 rounded-lg bg-white/5 text-sm text-white cursor-pointer flex items-center justify-between gap-2 transition-all duration-200 hover:border-white/20 relative"
                       :class="{ 'border-orange-500/50 shadow-[0_0_12px_rgba(255,107,0,0.08)]': roleOpen }">
                    <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                      <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                    </div>
                    <span x-show="!branchSel" class="text-gray-500 text-sm">Seleccionar...</span>
                    <span x-show="branchSel" class="truncate font-semibold text-sm ml-auto" x-text="branchOptions.find(o => o.id == branchSel)?.name"></span>
                    <svg class="w-3.5 h-3.5 text-gray-500 shrink-0 transition-transform duration-200" :class="{ 'rotate-180': branchOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 9l6 6 6-6"/></svg>
                  </div>
                  <div x-show="branchOpen"
                       x-transition:enter="transition ease-out duration-150"
                       x-transition:enter-start="opacity-0 -translate-y-1"
                       x-transition:enter-end="opacity-100 translate-y-0"
                       class="absolute z-50 top-full left-0 right-0 mt-1 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl overflow-y-auto max-h-60 shadow-2xl">
                    <template x-for="(b, i) in branchOptions" :key="b.id">
                      <div @click="branchPick(b)"
                           @mouseenter="branchIdx = i" @mouseleave="branchIdx = -1"
                           :class="{ 'bg-white/[0.07]': branchIdx === i, 'text-orange-400': b.id == branchSel }"
                           class="px-3 py-2.5 cursor-pointer border-b border-white/5 transition-colors duration-100 last:border-0 text-sm font-semibold"
                           x-text="b.name">
                      </div>
                    </template>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
              <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                </svg>
              </div>
              <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Contacto y Dirección</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-3.5">
              <div x-show="requiereContacto"
                   x-transition:enter="transition ease-out duration-200"
                   x-transition:enter-start="opacity-0 scale-95"
                   x-transition:enter-end="opacity-100 scale-100">
                <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" x-text="contactoLabel"></label>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  </div>
                  <%= f.text_field :contacto_root,
                      "x-bind:placeholder": "contactoPlaceholder",
                      class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
              <div :class="requiereContacto ? '' : 'lg:col-span-3'">
                <%= f.label :address, "Dirección", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                  </div>
                  <%= f.text_field :address, placeholder: "Calle, Nro, Ciudad", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <%= f.submit "Actualizar Usuario",
                     class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-8 py-3 rounded-xl text-sm font-black cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 active:scale-[0.98]" %>
            <%= link_to "Cancelar", admin_user_path(@user),
                    class: "text-gray-400 no-underline text-sm font-bold px-4 py-3 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
