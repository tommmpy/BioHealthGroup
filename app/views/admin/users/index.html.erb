<% role_order = {
  "administrador" => 0, "medico" => 1, "recepcionista" => 2,
  "operario" => 3, "disenador" => 4, "paciente" => 5
} %>
<% role_labels = {
  "administrador" => { title: "Administradores", icon: "M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z", color: "text-red-400", bg: "bg-red-500/10", badge: "text-red-400 bg-red-500/10" },
  "medico" => { title: "Médicos", icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z", color: "text-blue-400", bg: "bg-blue-500/10", badge: "text-blue-400 bg-blue-500/10" },
  "recepcionista" => { title: "Recepcionistas", icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0a1 1 0 01-1-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 01-1 1h-2z", color: "text-emerald-400", bg: "bg-emerald-500/10", badge: "text-emerald-400 bg-emerald-500/10" },
  "operario" => { title: "Operarios", icon: "M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z", color: "text-purple-400", bg: "bg-purple-500/10", badge: "text-purple-400 bg-purple-500/10" },
  "disenador" => { title: "Diseñadores", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01", color: "text-pink-400", bg: "bg-pink-500/10", badge: "text-pink-400 bg-pink-500/10" },
  "paciente" => { title: "Pacientes", icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z", color: "text-orange-400", bg: "bg-orange-500/10", badge: "text-orange-400 bg-orange-500/10" }
} %>
<% grouped = @users.group_by { |u| u.role }.sort_by { |role, _| role_order[role] || 99 } %>
<% roles = grouped.map(&:first) %>

<div class="px-4 mt-8 lg:mt-12 animate-fade-up">

  <div class="max-w-7xl mx-auto bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 lg:mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0">Gestión de Personal</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @users.count %> USUARIOS
      </div>
    </div>
    <%= link_to new_admin_user_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-2.5 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 inline-flex items-center gap-2 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 shrink-0" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nuevo usuario
    <% end %>
  </div>

  <div x-data="{
    search: '',
    open: { <%= grouped.map { |role, users| "#{role}: #{users.any?}" }.join(", ") %> },
    counts: {},
    updateCounts() {
      var self = this, s = self.search.toLowerCase();
      <%= roles.map { |r|
        "var c#{r} = Array.from(self.$refs['section-#{r}']?.querySelectorAll('[data-card]') || []); var v#{r} = 0; c#{r}.forEach(function(el){ if (el.textContent.toLowerCase().includes(s)) v#{r}++; }); self.counts['#{r}'] = v#{r}; if (v#{r} > 0) self.open.#{r} = true"
      }.join("; ") %>
    }
  }" x-init="updateCounts(); $watch('search', () => updateCounts())">

    <div class="relative max-w-md mb-5">
      <svg class="absolute left-4 inset-y-0 w-[18px] h-full text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text"
             x-model="search"
             placeholder="Filtrar por nombre, email, CI o teléfono..."
             class="w-full pl-11 pr-4 py-3 border border-white/10 rounded-xl bg-black/80 backdrop-blur-xl text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600">
    </div>

    <div class="max-w-7xl mx-auto flex flex-col gap-4 lg:gap-5">

    <% grouped.each do |role, users| %>
      <% rs = role_labels[role] || role_labels.values.first %>
      <div x-ref="section-<%= role %>"
           class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden transition-all duration-200 hover:border-orange-500/20"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <button @click="open.<%= role %> = !open.<%= role %>"
                class="w-full flex items-center justify-between p-4 lg:p-5 bg-transparent border-none cursor-pointer text-left group">
          <h3 class="m-0 text-sm font-bold text-gray-400 uppercase tracking-wider group-hover:text-orange-400 transition-colors duration-200 flex items-center gap-2">
            <svg class="w-4 h-4 <%= rs[:color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= rs[:icon] %>"/></svg>
            <%= rs[:title] %>
            <span class="text-gray-600 ml-0.5 font-semibold">(<span x-text="counts['<%= role %>'] || 0">0</span>)</span>
          </h3>
          <svg class="w-4 h-4 text-gray-600 transition-all duration-300 group-hover:text-orange-400"
               :class="{ 'rotate-180': open.<%= role %> }"
               fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div x-show="open.<%= role %>"
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0"
             x-transition:enter-end="opacity-100"
             class="px-4 lg:px-5 pb-4 lg:pb-5">
          <div class="grid gap-3">
            <% users.sort_by { |u| "#{u.first_name} #{u.last_name}" }.each do |user| %>
              <div x-show="search === '' || $el.textContent.toLowerCase().includes(search.toLowerCase())"
                   data-card="true"
                   class="bg-white/5 border border-white/5 rounded-xl p-4 flex flex-col sm:flex-row sm:items-center gap-3 transition-all duration-200 hover:bg-white/[0.07] hover:border-orange-500/20">
                <div class="flex items-center gap-3 min-w-0 sm:flex-1">
                  <div class="w-9 h-9 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-xs font-black text-black shrink-0">
                    <%= user.first_name[0] %><%= user.last_name[0] %>
                  </div>
                  <div class="min-w-0">
                    <div class="font-bold text-white text-sm truncate"><%= link_to "#{user.first_name} #{user.last_name}", admin_user_path(user), class: "text-white no-underline hover:text-orange-400 transition-colors duration-200" %></div>
                    <div class="flex flex-wrap items-center gap-x-3 gap-y-1 text-xs mt-0.5">
                      <span class="text-gray-500"><%= user.email_address %></span>
                      <% if user.ci.present? %>
                        <span class="text-gray-500">CI: <%= user.ci %></span>
                      <% end %>
                      <% if user.phone_number.present? %>
                        <span class="text-gray-500"><%= user.phone_number %></span>
                      <% end %>
                    </div>
                  </div>
                </div>
                <div class="flex items-center gap-3 flex-wrap sm:shrink-0">
                  <% if user.branch %>
                    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full bg-white/5 text-gray-400 border border-white/10 text-[11px] font-bold whitespace-nowrap">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
                      <%= user.branch.name %>
                    </span>
                  <% end %>
                  <%= render StatusBadgeComponent.new(status: user.status || "desconectado", label: user.status_label) %>
                  <%= link_to edit_admin_user_path(user), class: "no-underline p-1.5 bg-white/5 text-orange-400 rounded-lg border border-white/10 transition-all duration-200 hover:bg-orange-500/10 hover:border-orange-500/50 hover:scale-110 inline-flex", title: "Editar" do %>
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                  <% end %>
                  <% if user.id == current_user&.id %>
                    <span class="bg-white/5 text-gray-500 px-1.5 py-0.5 rounded text-[10px] font-bold border border-white/10 uppercase leading-tight">Tú</span>
                  <% else %>
                    <button type="button"
                      onclick="window.dispatchEvent(new CustomEvent('confirm-delete', { detail: { url: '<%= j admin_user_path(user) %>', name: '<%= j "#{user.first_name} #{user.last_name}" %>' } }))"
                      class="p-1.5 bg-red-500/10 text-red-400 rounded-lg border border-red-500/20 cursor-pointer transition-all duration-200 flex items-center hover:bg-red-500/20 hover:border-red-500/50 hover:scale-110">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                      </svg>
                    </button>
                  <% end %>
                </div>
              </div>
            <% end %>
            <% if users.empty? %>
              <div class="text-center py-8 text-gray-500 text-sm">No hay usuarios en este rol.</div>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>

    <% if grouped.empty? %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-10 text-center relative"
           style="box-shadow: 0 0 20px rgba(255,107,0,0.02), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z"/></svg>
        <p class="text-gray-500 font-semibold">No hay usuarios registrados.</p>
      </div>
    <% end %>
  </div>

  <div id="delete-modal"
       x-data="{ open: false, actionUrl: '', userName: '' }"
       @confirm-delete.window="open = true; actionUrl = $event.detail.url; userName = $event.detail.name"
       @keydown.escape.window="open = false"
       x-show="open"
       class="fixed inset-0 z-[9999] w-screen h-screen"
       style="display: none;">
    <div x-show="open"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         class="absolute inset-0 bg-black/80 backdrop-blur-md">
    </div>
    <div class="relative w-full h-full flex items-center justify-center p-5">
      <div @click.away="open = false"
           x-show="open"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-90"
           x-transition:enter-end="opacity-100 scale-100"
           class="bg-black/90 backdrop-blur-xl border border-white/10 w-full max-w-sm rounded-3xl p-8 lg:p-10 text-center shadow-2xl"
           style="box-shadow: 0 0 50px rgba(255,107,0,0.1), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="bg-red-500/10 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-5 border border-red-500/20">
          <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
          </svg>
        </div>
        <h3 class="text-white text-xl lg:text-2xl font-black m-0 mb-2.5">¿Estás seguro?</h3>
        <p class="text-gray-500 text-sm leading-relaxed m-0 mb-8">
          Estás por eliminar a:<br>
          <strong class="text-orange-500" x-text="userName"></strong>
        </p>
        <div class="flex gap-3">
          <button @click="open = false"
                  class="flex-1 bg-white/5 text-gray-400 border border-white/10 p-3.5 rounded-xl font-bold text-sm cursor-pointer transition-all duration-200 hover:text-white hover:border-orange-500/50">
            CANCELAR
          </button>
          <form :action="actionUrl" method="post" class="flex-1 m-0">
            <input type="hidden" name="_method" value="delete">
            <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
            <button type="submit"
                    class="w-full bg-gradient-to-r from-red-500 to-red-600 text-white border-none p-3.5 rounded-xl font-black text-sm cursor-pointer shadow-lg shadow-red-500/25 transition-all duration-300 hover:shadow-red-500/40 hover:scale-[1.02]">
              ELIMINAR
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>

  <% if @pagy && @pagy.pages > 1 %>
    <div class="mt-6 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>