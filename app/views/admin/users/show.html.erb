<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-4xl relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative transition-all duration-300"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="px-5 sm:px-7 pt-5 sm:pt-7 pb-2">
        <div class="flex items-center gap-4 pb-4 mb-2 border-b border-white/5">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-lg font-black text-black shadow-lg shadow-orange-500/25 shrink-0">
            <%= @user.first_name[0] %><%= @user.last_name[0] %>
          </div>
          <div class="min-w-0">
            <div class="flex items-center gap-2 flex-wrap">
              <h1 class="text-xl sm:text-2xl font-black text-white tracking-tight m-0"><%= "#{@user.first_name} #{@user.last_name}" %></h1>
              <%= render StatusBadgeComponent.new(status: @user.status || "desconectado", label: @user.status_label) %>
            </div>
            <p class="text-gray-500 text-sm mt-0.5">
              <%= @user.role&.humanize %>
              <span class="text-gray-600">·</span>
              <%= @user.email_address %>
            </p>
          </div>
        </div>
      </div>

      <div class="px-5 sm:px-7 pb-5 sm:pb-7 flex flex-col gap-4">
        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
          <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
              </svg>
            </div>
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Información Personal</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Cédula</span>
              <p class="text-white text-sm font-semibold"><%= @user.ci || "—" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Fecha de Nacimiento</span>
              <p class="text-white text-sm font-semibold"><%= @user.birthday&.strftime("%d/%m/%Y") || "—" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Tipo</span>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold uppercase border <%= @user.empresa? ? "text-blue-400 border-blue-500/20 bg-blue-500/10" : "text-orange-400 border-orange-500/20 bg-white/5" %>">
                <%= @user.user_type&.humanize || "Persona" %>
              </span>
            </div>
          </div>
        </div>

        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
          <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Contacto y Dirección</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Email</span>
              <p class="text-white text-sm font-semibold"><%= @user.email_address %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Teléfono</span>
              <p class="text-white text-sm font-semibold"><%= @user.phone_number || "—" %></p>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Contacto de emergencia</span>
              <p class="text-white text-sm font-semibold"><%= @user.contacto_root.presence || "—" %></p>
            </div>
            <div class="sm:col-span-2 lg:col-span-3">
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Dirección</span>
              <p class="text-white text-sm font-semibold"><%= @user.address.presence || "—" %></p>
            </div>
          </div>
        </div>

        <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
          <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
            <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
              <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Configuración de Cuenta</h2>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Rol</span>
              <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-bold uppercase bg-white/5 text-orange-400 border border-orange-500/20">
                <%= @user.role&.humanize %>
              </span>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Sucursal</span>
              <% if @user.branch %>
                <p class="text-white text-sm font-semibold"><%= @user.branch.name %></p>
              <% else %>
                <p class="text-gray-500 text-sm italic">Sin sede</p>
              <% end %>
            </div>
            <div>
              <span class="block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1">Registrado</span>
              <p class="text-white text-sm font-semibold"><%= @user.created_at&.strftime("%d/%m/%Y") || "—" %></p>
            </div>
          </div>
        </div>

        <% user_activities = @user.sessions.where("jsonb_array_length(activity_log) > 0").order(updated_at: :desc).limit(5).flat_map { |s| (s.activity_log || []).map { |e| e.merge("session_id" => s.id, "user_name" => s.user_name) } }.sort_by { |e| e["visited_at"] }.reverse.first(10) %>
        <% if user_activities.any? %>
          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5 mt-5">
            <div class="flex items-center gap-2 mb-4">
              <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"/></svg>
              <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Actividad reciente</span>
            </div>
            <div class="flex flex-col gap-1.5">
              <% user_activities.each do |entry| %>
                <div class="flex items-start gap-2 py-1.5 px-2 rounded-lg hover:bg-white/[0.02] transition-colors">
                  <div class="w-1.5 h-1.5 rounded-full bg-orange-500/60 mt-1.5 shrink-0"></div>
                  <div class="flex-1 min-w-0">
                    <p class="m-0 text-sm text-gray-300"><%= entry["description"] || entry["action"]&.humanize %></p>
                    <p class="m-0 text-[10px] text-gray-600"><%= time_ago_in_words(Time.parse(entry["visited_at"])) %> &middot; <%= entry["method"] %></p>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>

        <div class="flex items-center gap-3 pt-2">
          <%= link_to edit_admin_user_path(@user), class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-8 py-3 rounded-xl text-sm font-black shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 active:scale-[0.98] inline-flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
            Editar usuario
          <% end %>
          <%= link_to admin_users_path, class: "text-gray-400 no-underline text-sm font-bold px-4 py-3 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5 inline-flex items-center gap-2" do %>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
            Volver
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
