<% sections = [
  { key: "progreso", title: "En progreso", filter: ->(e) { e.en_progreso? }, icon: "M13 10V3L4 14h7v7l9-11h-7z", color: "text-blue-400", bg: "bg-blue-500/10", badge: "text-blue-400 bg-blue-500/10" },
  { key: "pendientes", title: "Pendientes", filter: ->(e) { e.pendiente? }, icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z", color: "text-yellow-400", bg: "bg-yellow-500/10", badge: "text-yellow-400 bg-yellow-500/10" },
  { key: "finalizados", title: "Finalizados", filter: ->(e) { e.finalizado? }, icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z", color: "text-green-400", bg: "bg-green-500/10", badge: "text-green-400 bg-green-500/10" },
] %>
<% section_keys = sections.map { |s| s[:key] } %>

<div class="w-full mx-auto px-3 sm:px-4 lg:px-10 py-4 sm:py-6 lg:py-8 animate-fade-up">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 sm:mb-8 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Gestión de Estudios</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @estudios.count %> ESTUDIOS
      </div>
    </div>
    <div class="flex items-center gap-2.5">
      <%= link_to admin_estudios_path(format: :csv, params: request.query_parameters.except(:format)), class: "border border-white/10 text-gray-400 no-underline px-4 py-3 rounded-xl text-[11px] font-bold transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400 hover:bg-orange-500/5 inline-flex items-center gap-2" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        CSV
      <% end %>
      <% if is_administrador? || is_recepcionista? %>
        <%= link_to new_admin_estudio_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 inline-flex items-center gap-2 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 shrink-0" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Agendar estudio
        <% end %>
      <% end %>
    </div>
  </div>

  <div x-data="{ advancedOpen: false }" class="mb-5">
    <button @click="advancedOpen = !advancedOpen" class="flex items-center gap-2 text-gray-400 text-sm font-semibold transition-colors duration-200 hover:text-orange-400 bg-transparent border-none cursor-pointer">
      <svg class="w-4 h-4" :class="{ 'rotate-180': advancedOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4"/></svg>
      Búsqueda avanzada
      <% if params[:q].present? %>
        <span class="bg-orange-500/10 text-orange-400 text-[10px] font-bold px-2 py-0.5 rounded-full">activo</span>
      <% end %>
    </button>
    <div x-show="advancedOpen"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         class="mt-3">
      <%= search_form_for @q, url: admin_estudios_path, method: :get, local: true, class: "bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-5 relative",
          style: "box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);" do |f| %>
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-4">
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Nombre</label>
            <%= f.search_field :nombre_completo_cont, value: params.dig(:q, :nombre_completo_cont), placeholder: "Buscar por nombre...", class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Cédula</label>
            <%= f.search_field :user_ci_cont, value: params.dig(:q, :user_ci_cont), placeholder: "Buscar por CI...", class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Paciente (nombre)</label>
            <%= f.search_field :user_first_name_or_user_last_name_cont, value: params.dig(:q, :user_first_name_or_user_last_name_cont), placeholder: "Nombre del paciente...", class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Estado</label>
            <%= f.select :estado_eq, options_for_select(Estudio.estados.keys.map { |k| [k.humanize, k] }, params.dig(:q, :estado_eq)), { include_blank: "Todos" }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Sucursal</label>
            <%= f.collection_select :branch_id_eq, Branch.all, :id, :name, { include_blank: "Todas", selected: params.dig(:q, :branch_id_eq) }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Médico</label>
            <%= f.collection_select :medico_id_eq, User.where(role: User.roles[:medico]), :id, ->(u) { "#{u.first_name} #{u.last_name}" }, { include_blank: "Todos", selected: params.dig(:q, :medico_id_eq) }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha desde</label>
            <%= f.date_field :fecha_estudio_gteq, value: params.dig(:q, :fecha_estudio_gteq), class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha hasta</label>
            <%= f.date_field :fecha_estudio_lteq, value: params.dig(:q, :fecha_estudio_lteq), class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
        </div>
        <div class="flex items-center gap-3 pt-2 border-t border-white/5">
          <%= f.submit "Filtrar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-6 py-2.5 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 hover:scale-105" %>
          <%= link_to admin_estudios_path, class: "text-gray-400 no-underline text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" do %>
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            Limpiar
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div x-data="{
    search: '',
    open: { <%= sections.map { |s| items = @estudios.select { |e| s[:filter].call(e) }; "#{s[:key]}: #{items.any?}" }.join(", ") %> },
    counts: { <%= section_keys.map { |k| "#{k}: 0" }.join(", ") %> },
    updateCounts() {
      var self = this, s = self.search.toLowerCase();
      <%= section_keys.map { |k|
        "var c#{k} = Array.from(self.$refs['section-#{k}']?.querySelectorAll('[data-card]') || []); var v#{k} = 0; c#{k}.forEach(function(el){ if (el.textContent.toLowerCase().includes(s)) v#{k}++; }); self.counts.#{k} = v#{k}; if (v#{k} > 0) self.open.#{k} = true"
      }.join("; ") %>
    }
  }" x-init="updateCounts(); $watch('search', () => updateCounts())">

    <div class="relative mb-5 max-w-md">
      <svg class="absolute left-4 inset-y-0 w-[18px] h-full text-gray-500 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
      <input type="text"
             x-model="search"
             placeholder="Filtrar por paciente, CI o médico..."
             class="w-full pl-11 pr-4 py-3 border border-white/10 rounded-xl bg-black/80 backdrop-blur-xl text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600">
    </div>

    <div class="flex flex-col gap-4 lg:gap-5">

      <% sections.each do |section| %>
        <% items = @estudios.select { |e| section[:filter].call(e) } %>
        <div x-ref="section-<%= section[:key] %>"
             class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden transition-all duration-200 hover:border-orange-500/20"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <button @click="open.<%= section[:key] %> = !open.<%= section[:key] %>"
                  class="w-full flex items-center justify-between p-4 lg:p-5 bg-transparent border-none cursor-pointer text-left group">
            <h3 class="m-0 text-sm font-bold text-gray-400 uppercase tracking-wider group-hover:text-orange-400 transition-colors duration-200 flex items-center gap-2">
              <svg class="w-4 h-4 <%= section[:color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= section[:icon] %>"/></svg>
              <%= section[:title] %>
              <span class="text-gray-600 ml-0.5 font-semibold">(<span x-text="counts.<%= section[:key] %>">0</span>)</span>
            </h3>
            <svg class="w-4 h-4 text-gray-600 transition-all duration-300 group-hover:text-orange-400"
                 :class="{ 'rotate-180': open.<%= section[:key] %> }"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div x-show="open.<%= section[:key] %>"
               x-transition:enter="transition ease-out duration-200"
               x-transition:enter-start="opacity-0"
               x-transition:enter-end="opacity-100"
               class="px-4 lg:px-5 pb-4 lg:pb-5">
            <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-3">
              <% if items.any? %>
                <% items.each do |estudio| %>
                  <div x-show="search === '' || $el.textContent.toLowerCase().includes(search.toLowerCase())"
                       data-card="true"
                       class="bg-white/5 border border-white/5 rounded-xl p-4 transition-all duration-200 hover:bg-white/[0.07] hover:border-orange-500/20">
                    <div class="flex flex-col sm:flex-row sm:items-start gap-3">
                      <div class="min-w-0 flex-1">
                        <div class="flex items-center gap-3 flex-wrap">
                          <div class="w-9 h-9 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-xs font-black text-black shrink-0">
                            <%= estudio.nombre_completo.split.tap { |parts| break parts.size >= 2 ? "#{parts.first[0]}#{parts.last[0]}" : parts.first[0..1] } %>
                          </div>
                          <div class="min-w-0">
                            <div class="font-bold text-white text-sm truncate"><%= estudio.nombre_completo %></div>
                            <div class="text-gray-500 text-xs flex flex-wrap items-center gap-x-2">
                              <span><%= estudio.fecha_estudio.strftime("%d/%m/%Y %H:%M") %></span>
                              <span class="text-gray-700">·</span>
                              <span><%= estudio.branch&.name || "Sin sede" %></span>
                            </div>
                          </div>
                          <% status_config = { "en_progreso" => "bg-blue-500/10 text-blue-400 border-blue-500/20", "pendiente" => "bg-yellow-500/10 text-yellow-400 border-yellow-500/20", "finalizado" => "bg-green-500/10 text-green-400 border-green-500/20" } %>
                          <span class="ml-auto <%= status_config[estudio.estado] || status_config.values.first %> text-[10px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border leading-tight"><%= estudio.estado.humanize %></span>
                        </div>

                        <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1.5 text-xs">
                          <span class="text-gray-500">
                            <span class="text-gray-600">CI:</span> <%= estudio.user&.ci || "—" %>
                          </span>
                          <span class="text-gray-500">
                            <span class="text-gray-600">Dr.</span> <%= estudio.medico.present? ? "#{estudio.medico.first_name} #{estudio.medico.last_name}" : "No asignado" %>
                          </span>
                          <span class="text-gray-500">
                            <span class="text-gray-600">Cant:</span> <%= estudio.cantidad_productos %>
                          </span>
                        </div>

                        <% if Array(estudio.tipo_producto).any? %>
                          <div class="mt-2 flex flex-wrap gap-1.5">
                            <% Array(estudio.tipo_producto).each do |prod| %>
                              <span class="bg-white/5 text-gray-400 border border-white/10 px-2.5 py-0.5 rounded-full text-[11px]"><%= prod %></span>
                            <% end %>
                          </div>
                        <% end %>
                      </div>

                      <div class="flex items-center gap-2 sm:flex-col sm:items-stretch shrink-0">
                        <% if estudio.en_progreso? && (is_medico? || is_administrador?) %>
                          <%= button_to "Finalizar", finalizar_admin_estudio_path(estudio), method: :patch,
                              form: { data: { turbo_confirm: "¿Confirma que el estudio ha terminado?" } },
                              class: "bg-gradient-to-r from-green-500 to-green-600 text-black border-none px-4 py-2 rounded-lg text-[11px] font-bold cursor-pointer shadow-lg shadow-green-500/20 transition-all duration-200 hover:shadow-green-500/30 hover:scale-105 whitespace-nowrap" %>
                        <% end %>
                        <% if estudio.pendiente? && (is_medico? || is_administrador?) %>
                          <%= button_to "Iniciar", iniciar_admin_estudio_path(estudio), method: :patch,
                              form: { data: { turbo_confirm: "¿Desea iniciar este estudio?" } },
                              class: "bg-gradient-to-r from-blue-500 to-blue-600 text-white border-none px-4 py-2 rounded-lg text-[11px] font-bold cursor-pointer shadow-lg shadow-blue-500/20 transition-all duration-200 hover:shadow-blue-500/30 hover:scale-105 whitespace-nowrap" %>
                        <% end %>
                        <%= link_to "Detalle", admin_estudio_path(estudio),
                            class: "border border-white/10 text-gray-400 no-underline px-4 py-2 rounded-lg text-[11px] font-bold text-center transition-all duration-200 hover:border-orange-500/50 hover:text-orange-400 hover:bg-orange-500/5" %>
                      </div>
                    </div>
                  </div>
                <% end %>
              <% else %>
                <div class="text-center py-10 text-gray-500 text-sm">
                  <svg class="w-8 h-8 mx-auto mb-2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                  No hay estudios <%= section[:title].downcase %>.
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>