<div class="px-4 mt-8 lg:mt-12 animate-fade-up">

  <div class="max-w-7xl mx-auto bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 mb-6 lg:mb-8 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0">Inventario de Productos</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @products.count %> PRODUCTOS
      </div>
    </div>
    <%= link_to new_admin_product_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-2.5 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 inline-flex items-center gap-2 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 shrink-0" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
      Nuevo producto
    <% end %>
  </div>

  <%= search_form_for @q, url: admin_products_path, method: :get, local: true, class: "max-w-7xl mx-auto bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-5 mb-5 relative",
      style: "box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);" do |f| %>
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Nombre</label>
        <%= f.search_field :name_cont, placeholder: "Buscar producto...", class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600" %>
      </div>
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Categoría</label>
        <%= f.select :category_eq, options_for_select(%w[plantar material accesorio].map { |c| [c.humanize, c] }, params.dig(:q, :category_eq)), { include_blank: "Todas" }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Sucursal</label>
        <%= f.collection_select :branch_id_eq, Branch.all, :id, :name, { include_blank: "Todas", selected: params.dig(:q, :branch_id_eq) }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>
      <div>
        <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Activo</label>
        <%= f.select :active_eq, options_for_select([["Sí", true], ["No", false]], params.dig(:q, :active_eq)), { include_blank: "Todos" }, class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
      </div>
    </div>
    <div class="flex items-center gap-3 mt-4 pt-3 border-t border-white/5">
      <%= f.submit "Filtrar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-6 py-2.5 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 hover:scale-105" %>
      <%= link_to admin_products_path, class: "text-gray-400 no-underline text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" do %>
        <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        Limpiar
      <% end %>
    </div>
  <% end %>

  <div class="max-w-7xl mx-auto grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
    <% @products.each do |product| %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-5 relative transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.02]"
           style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <div class="flex items-start justify-between mb-3">
          <div class="w-10 h-10 bg-gradient-to-br from-orange-500 to-orange-600 rounded-xl flex items-center justify-center shadow-lg shadow-orange-500/20 shrink-0">
            <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <div class="flex items-center gap-2">
            <% if product.active %>
              <span class="bg-green-500/10 text-green-400 text-[10px] font-bold px-2 py-0.5 rounded-full border border-green-500/20">Activo</span>
            <% else %>
              <span class="bg-red-500/10 text-red-400 text-[10px] font-bold px-2 py-0.5 rounded-full border border-red-500/20">Inactivo</span>
            <% end %>
          </div>
        </div>

        <h3 class="text-lg font-black text-white m-0 mb-1"><%= product.name %></h3>

        <% if product.description.present? %>
          <p class="text-gray-500 text-xs leading-relaxed mb-3 line-clamp-2"><%= product.description %></p>
        <% end %>

        <div class="flex flex-wrap gap-1.5 mb-3">
          <% if product.category.present? %>
            <span class="bg-white/5 text-gray-400 border border-white/10 px-2.5 py-0.5 rounded-full text-[11px]"><%= product.category.humanize %></span>
          <% end %>
          <% if product.branch.present? %>
            <span class="bg-white/5 text-gray-400 border border-white/10 px-2.5 py-0.5 rounded-full text-[11px]"><%= product.branch.name %></span>
          <% end %>
        </div>

        <div class="flex items-center justify-between pt-3 border-t border-white/5">
          <div>
            <span class="text-orange-500 text-lg font-black">$<%= number_with_delimiter(product.unit_price || 0) %></span>
          </div>
          <div class="text-right">
            <span class="text-gray-500 text-[11px] block leading-tight">Stock</span>
            <span class="<%= product.stock_quantity <= 0 ? 'text-red-400' : product.stock_quantity < 10 ? 'text-yellow-400' : 'text-green-400' %> font-bold text-sm"><%= product.stock_quantity %></span>
          </div>
        </div>

        <div class="flex items-center gap-2 mt-4">
          <%= link_to edit_admin_product_path(product), class: "flex-1 text-center no-underline py-2.5 bg-white/5 text-orange-400 rounded-lg border border-white/10 text-[11px] font-bold transition-all duration-200 hover:bg-orange-500/10 hover:border-orange-500/50 hover:scale-105" do %>
            Editar
          <% end %>
          <button type="button"
            onclick="window.dispatchEvent(new CustomEvent('confirm-delete', { detail: { url: '<%= j admin_product_path(product) %>', name: '<%= j product.name %>' } }))"
            class="flex-1 py-2.5 bg-red-500/10 text-red-400 rounded-lg border border-red-500/20 text-[11px] font-bold cursor-pointer transition-all duration-200 hover:bg-red-500/20 hover:border-red-500/50 hover:scale-105">
            Eliminar
          </button>
        </div>
      </div>
    <% end %>

    <% if @products.empty? %>
      <div class="col-span-full bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-10 text-center relative"
           style="box-shadow: 0 0 20px rgba(255,107,0,0.02), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <svg class="w-12 h-12 text-gray-600 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        <p class="text-gray-500 font-semibold">No hay productos registrados.</p>
        <%= link_to new_admin_product_path, class: "mt-3 inline-block bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 py-3 rounded-xl text-sm font-bold shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
          Crear primer producto
        <% end %>
      </div>
    <% end %>
  </div>
</div>

<div id="delete-modal"
     x-data="{ open: false, actionUrl: '', productName: '' }"
     @confirm-delete.window="open = true; actionUrl = $event.detail.url; productName = $event.detail.name"
     @keydown.escape.window="open = false"
     x-show="open"
     class="fixed inset-0 z-[9999] w-screen h-screen"
     style="display: none;">
  <div x-show="open"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0"
       x-transition:enter-end="opacity-100"
       class="absolute inset-0 bg-black/80 backdrop-blur-md">
  </div>
  <div class="relative w-full h-full flex items-center justify-center p-5">
    <div @click.away="open = false"
         x-show="open"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-90"
         x-transition:enter-end="opacity-100 scale-100"
         class="bg-black/90 backdrop-blur-xl border border-white/10 w-full max-w-sm rounded-3xl p-8 lg:p-10 text-center shadow-2xl"
         style="box-shadow: 0 0 50px rgba(255,107,0,0.1), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="bg-red-500/10 w-16 h-16 rounded-xl flex items-center justify-center mx-auto mb-5 border border-red-500/20">
        <svg class="w-8 h-8 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <h3 class="text-white text-xl lg:text-2xl font-black m-0 mb-2.5">¿Estás seguro?</h3>
      <p class="text-gray-500 text-sm leading-relaxed m-0 mb-8">
        Estás por eliminar:<br>
        <strong class="text-orange-500" x-text="productName"></strong>
      </p>
      <div class="flex gap-3">
        <button @click="open = false"
                class="flex-1 bg-white/5 text-gray-400 border border-white/10 p-3.5 rounded-xl font-bold text-sm cursor-pointer transition-all duration-200 hover:text-white hover:border-orange-500/50">
          CANCELAR
        </button>
        <form :action="actionUrl" method="post" class="flex-1 m-0">
          <input type="hidden" name="_method" value="delete">
          <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
          <button type="submit"
                  class="w-full bg-gradient-to-r from-red-500 to-red-600 text-white border-none p-3.5 rounded-xl font-black text-sm cursor-pointer shadow-lg shadow-red-500/25 transition-all duration-300 hover:shadow-red-500/40 hover:scale-[1.02]">
            ELIMINAR
          </button>
        </form>
      </div>
    </div>
  </div>
</div>
