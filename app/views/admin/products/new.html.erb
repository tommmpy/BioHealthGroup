<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-2xl relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="px-5 sm:px-7 pt-5 sm:pt-7 pb-2">
        <div class="flex items-center gap-4 pb-4 mb-2 border-b border-white/5">
          <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 shrink-0">
            <svg class="w-5.5 h-5.5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
          </div>
          <div>
            <h1 class="text-lg sm:text-xl font-black text-white tracking-tight">Nuevo Producto</h1>
            <p class="text-gray-500 text-xs sm:text-sm mt-0.5">Agregá un producto al inventario</p>
          </div>
        </div>
      </div>

      <%= form_with model: [:admin, @product] do |f| %>
        <% if @product.errors.any? %>
          <div class="mx-5 sm:mx-7 mb-4 bg-red-950/80 backdrop-blur border border-red-500/20 p-3 rounded-xl">
            <p class="text-red-400 text-xs font-bold mb-1">Errores al crear el producto:</p>
            <ul class="m-0 pl-4 text-gray-300 text-xs">
              <% @product.errors.full_messages.each do |msg| %>
                <li class="mb-0.5"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="px-5 sm:px-7 pb-5 sm:pb-7 flex flex-col gap-4">

          <div class="bg-white/[0.03] border border-white/[0.06] rounded-xl p-4 sm:p-5">
            <div class="flex items-center gap-2.5 mb-4 pb-3 border-b border-white/[0.06]">
              <div class="w-7 h-7 rounded-lg bg-gradient-to-br from-orange-500/20 to-orange-600/20 flex items-center justify-center">
                <svg class="w-3.5 h-3.5 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                </svg>
              </div>
              <h2 class="text-xs font-bold text-gray-400 uppercase tracking-wider m-0">Información del Producto</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-4 gap-y-3.5">
              <div class="sm:col-span-2">
                <%= f.label :name, "Nombre", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <svg class="w-3.5 h-3.5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  </div>
                  <%= f.text_field :name, placeholder: "Ej: Plantar de uso diario", class: "w-full pl-8 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>

              <div class="sm:col-span-2">
                <%= f.label :description, "Descripción", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <%= f.text_area :description, rows: 3, placeholder: "Descripción del producto...", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)] resize-none" %>
              </div>

              <div>
                <%= f.label :category, "Categoría", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <%= f.select :category, options_for_select([["Plantar", "plantar"], ["Material", "material"], ["Accesorio", "accesorio"]]), { prompt: "Seleccionar..." }, class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
              </div>

              <div>
                <%= f.label :unit_price, "Precio unitario ($)", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 pl-2.5 flex items-center pointer-events-none">
                    <span class="text-gray-600 text-sm font-semibold">$</span>
                  </div>
                  <%= f.number_field :unit_price, step: "0.01", min: 0, placeholder: "0.00", class: "w-full pl-7 p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
                </div>
              </div>

              <div>
                <%= f.label :stock_quantity, "Stock inicial", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <%= f.number_field :stock_quantity, min: 0, placeholder: "0", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 placeholder:text-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
              </div>

              <div>
                <%= f.label :branch_id, "Sucursal (opcional)", class: "block text-[10px] font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
                <%= f.collection_select :branch_id, Branch.all, :id, :name, { prompt: "Todas las sucursales" }, class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-lg text-sm text-white outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_12px_rgba(255,107,0,0.08)]" %>
              </div>

              <div class="flex items-center gap-3 pt-2">
                <%= f.check_box :active, checked: true, class: "accent-orange-500 w-4 h-4" %>
                <%= f.label :active, "Producto activo", class: "text-sm text-gray-400 m-0" %>
              </div>
            </div>
          </div>

          <div class="flex items-center gap-3 pt-2">
            <%= f.submit "Crear Producto",
                     class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-8 py-3 rounded-xl text-sm font-black cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 active:scale-[0.98]" %>
            <%= link_to "Cancelar", admin_products_path,
                    class: "text-gray-400 no-underline text-sm font-bold px-4 py-3 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
