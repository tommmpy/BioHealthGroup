<% status_colors = {
  "draft" => "bg-gray-500/10 text-gray-400 border-gray-500/20",
  "sent" => "bg-blue-500/10 text-blue-400 border-blue-500/20",
  "paid" => "bg-green-500/10 text-green-400 border-green-500/20",
  "overdue" => "bg-red-500/10 text-red-400 border-red-500/20",
  "cancelled" => "bg-gray-500/10 text-gray-400 border-gray-500/20"
} %>

<% status_labels = { "draft" => "Borrador", "sent" => "Enviada", "paid" => "Pagada", "overdue" => "Vencida", "cancelled" => "Anulada" } %>

<div class="w-full mx-auto px-3 sm:px-4 lg:px-10 py-4 sm:py-6 lg:py-8 animate-fade-up">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 sm:mb-8 bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 lg:p-8 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div class="flex items-center gap-3">
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Facturación</h1>
      <div class="bg-gradient-to-r from-orange-500 to-orange-600 text-black px-4 py-2 rounded-full font-black text-xs tracking-wider whitespace-nowrap shadow-lg shadow-orange-500/20">
        <%= @invoices.count %> FACTURAS
      </div>
    </div>
    <div class="flex items-center gap-2.5">
      <% if is_administrador? || is_recepcionista? %>
        <%= link_to new_admin_invoice_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-black uppercase tracking-wider shadow-lg shadow-orange-500/25 inline-flex items-center gap-2 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 shrink-0" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/></svg>
          Nueva factura
        <% end %>
      <% end %>
    </div>
  </div>

  <div x-data="{ advancedOpen: false }" class="mb-5">
    <button @click="advancedOpen = !advancedOpen" class="flex items-center gap-2 text-gray-400 text-sm font-semibold transition-colors duration-200 hover:text-orange-400 bg-transparent border-none cursor-pointer">
      <svg class="w-4 h-4" :class="{ 'rotate-180': advancedOpen }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 100-4m0 4v2m0-6V4"/></svg>
      Filtros
      <% if params[:status].present? || params[:from_date].present? || params[:to_date].present? %>
        <span class="bg-orange-500/10 text-orange-400 text-[10px] font-bold px-2 py-0.5 rounded-full">activo</span>
      <% end %>
    </button>
    <div x-show="advancedOpen"
         x-transition:enter="transition ease-out duration-200"
         x-transition:enter-start="opacity-0 -translate-y-2"
         x-transition:enter-end="opacity-100 translate-y-0"
         class="mt-3">
      <%= form_tag admin_invoices_path, method: :get, local: true, class: "bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-5 relative",
          style: "box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);" do %>
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-4">
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Estado</label>
            <%= select_tag :status, options_for_select([["Todos", ""], ["Borrador", "draft"], ["Enviada", "sent"], ["Pagada", "paid"], ["Vencida", "overdue"], ["Anulada", "cancelled"]], params[:status]), class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha desde</label>
            <%= date_field_tag :from_date, params[:from_date], class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <label class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-1.5 block">Fecha hasta</label>
            <%= date_field_tag :to_date, params[:to_date], class: "w-full border border-white/10 rounded-xl bg-black/60 text-white text-sm py-2.5 px-3 outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
        </div>
        <div class="flex items-center gap-3 pt-2 border-t border-white/5">
          <%= submit_tag "Filtrar", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-6 py-2.5 rounded-xl font-bold text-sm cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-200 hover:shadow-orange-500/40 hover:scale-105" %>
          <%= link_to admin_invoices_path, class: "text-gray-400 no-underline text-sm font-semibold px-4 py-2.5 rounded-xl transition-all duration-200 hover:text-orange-400 hover:bg-white/5" do %>
            <svg class="w-4 h-4 inline mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            Limpiar
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden"
       style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10 pointer-events-none"></div>

    <% if @invoices.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-white/5">
              <th class="text-left text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Factura</th>
              <th class="text-left text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Paciente</th>
              <th class="text-left text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Total</th>
              <th class="text-left text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Estado</th>
              <th class="text-left text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Vencimiento</th>
              <th class="text-right text-gray-500 text-[11px] font-bold uppercase tracking-wider px-5 py-4">Acción</th>
            </tr>
          </thead>
          <tbody>
            <% @invoices.each do |invoice| %>
              <tr class="border-b border-white/5 transition-colors duration-150 hover:bg-white/[0.03]">
                <td class="px-5 py-4">
                  <div class="font-bold text-white"><%= invoice.invoice_number %></div>
                  <div class="text-gray-500 text-xs mt-0.5"><%= invoice.created_at.strftime("%d/%m/%Y") %></div>
                </td>
                <td class="px-5 py-4">
                  <div class="font-semibold text-white"><%= invoice.user.first_name %> <%= invoice.user.last_name %></div>
                  <div class="text-gray-500 text-xs mt-0.5"><%= invoice.user.ci %></div>
                </td>
                <td class="px-5 py-4">
                  <span class="font-bold text-white">$ <%= number_with_delimiter(invoice.total) %></span>
                </td>
                <td class="px-5 py-4">
                  <span class="<%= status_colors[invoice.status] %> text-[11px] font-bold uppercase tracking-wider px-3 py-1 rounded-full border leading-tight"><%= status_labels[invoice.status] %></span>
                </td>
                <td class="px-5 py-4">
                  <span class="<%= invoice.overdue? ? 'text-red-400' : 'text-gray-400' %> font-semibold text-sm"><%= invoice.due_date.strftime("%d/%m/%Y") %></span>
                </td>
                <td class="px-5 py-4 text-right">
                  <%= link_to admin_invoice_path(invoice), class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-4 py-2 rounded-lg text-[11px] font-bold inline-flex items-center gap-1.5 shadow-lg shadow-orange-500/20 transition-all duration-200 hover:shadow-orange-500/30 hover:scale-105" do %>
                    Ver detalle
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-16">
        <svg class="w-12 h-12 mx-auto mb-3 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        <p class="text-gray-500 text-base font-semibold m-0">No hay facturas registradas</p>
        <p class="text-gray-600 text-sm mt-1">Creá una nueva factura para comenzar.</p>
        <% if is_administrador? || is_recepcionista? %>
          <%= link_to new_admin_invoice_path, class: "inline-block mt-5 bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 py-3 rounded-xl text-sm font-bold shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
            + Nueva factura
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
