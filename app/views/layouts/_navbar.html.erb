<nav class="sticky top-0 z-100 font-sans"
   x-data="{ mobileOpen: false, contactOpen: false }"
   style="background: rgba(0,0,0,0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid rgba(255,107,0,0.15); box-shadow: 0 4px 30px rgba(0,0,0,0.5);">
  <div class="max-w-7xl mx-auto px-3 sm:px-4 lg:px-6">
    <div class="flex justify-between items-center h-14 sm:h-16 lg:h-20">

      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center gap-4 no-underline group" do %>
          <div class="flex items-center transition-transform duration-300 group-hover:scale-105">
            <%= image_tag "logo_bhg.webp",
              alt: "BHG Logo",
              class: "h-8 w-auto object-contain block" %>
          </div>
        <% end %>
      </div>

      <div class="hidden lg:flex items-center gap-1 ml-4">
        <%= link_to "Inicio", root_path, class: "text-gray-400 no-underline text-sm font-bold px-3 py-2 rounded-lg transition-all duration-200 hover:text-orange-400 hover:bg-orange-500/10" %>
        <%= link_to "Dashboard", user_dashboard_path, class: "text-gray-400 no-underline text-sm font-bold px-3 py-2 rounded-lg transition-all duration-200 hover:text-orange-400 hover:bg-orange-500/10" %>
        <button @click="contactOpen = !contactOpen"
                class="text-gray-400 text-sm font-bold px-3 py-2 rounded-lg transition-all duration-200 hover:text-orange-400 hover:bg-orange-500/10 cursor-pointer border-none bg-transparent">
          Contáctanos
        </button>
        <% if authenticated? && is_administrador? %>
          <%= link_to "Panel Admin", admin_dashboard_path,
              class: "text-orange-500 no-underline text-sm font-bold px-3 py-2 rounded-lg transition-all duration-200 hover:bg-orange-500/10" %>
        <% end %>
      </div>

      <div class="hidden lg:flex items-center gap-5">
        <% if !authenticated? %>
          <%= link_to new_session_path,
              class: "bg-gradient-to-r from-orange-500 to-orange-600 text-white border-none px-7 py-3 rounded-xl text-xs font-black tracking-wide cursor-pointer uppercase no-underline shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
            Iniciar sesión
          <% end %>
        <% end %>
        <% if authenticated? %>
          <% unread_count = current_user.notifications.unread.count %>
          <div data-controller="notifications">
            <%= link_to notifications_path, class: "relative no-underline text-gray-300 transition-colors duration-200 hover:text-orange-400 p-1.5" do %>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg>
              <span data-notifications-target="badge"
                    class="<%= unread_count > 0 ? '' : 'hidden' %> absolute -top-0.5 -right-0.5 w-4 h-4 rounded-full bg-orange-500 text-black text-[9px] font-black flex items-center justify-center shadow-lg shadow-orange-500/30"><%= unread_count > 9 ? "9+" : unread_count %></span>
            <% end %>
          </div>
          <div class="flex items-center gap-2 relative"
               x-data="{ open: false }"
               @click.away="open = false">
            <button @click="open = !open"
                    class="flex items-center gap-1.5 bg-none border-none cursor-pointer text-gray-300 text-sm font-semibold px-2 py-1 rounded-lg transition-all duration-200 hover:bg-white/5 hover:text-orange-400"
                    title="Cambiar estado">
              <div class="w-2.5 h-2.5 rounded-full <%= User::STATUS_COLORS[current_user.status] || 'bg-gray-600' %> shadow-lg shadow-current/20 shrink-0"></div>
              <span><%= User::STATUS_LABELS[current_user.status] || "Desconectado" %></span>
              <svg class="w-3 h-3 text-gray-500 transition-transform duration-200" :class="{ 'rotate-180': open }" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div x-show="open"
                 x-transition:enter="transition ease-out duration-150"
                 x-transition:enter-start="opacity-0 scale-95"
                 x-transition:enter-end="opacity-100 scale-100"
                 x-transition:leave="transition ease-in duration-100"
                 x-transition:leave-start="opacity-100 scale-100"
                 x-transition:leave-end="opacity-0 scale-95"
                 style="display: none;"
                 class="absolute top-full left-0 mt-1.5 w-44 bg-black/95 backdrop-blur-xl border border-white/10 rounded-xl py-1 shadow-2xl shadow-orange-500/5 z-50">
              <% User::STATUSES.slice(:disponible, :ausente, :no_molestar).each do |key, val| %>
                <%= button_to profile_status_path, method: :patch, params: { status: key },
                    class: "w-full flex items-center gap-2.5 px-3.5 py-2.5 text-sm font-semibold text-left transition-all duration-150 border-none bg-transparent cursor-pointer #{current_user.status == key.to_s ? 'text-orange-400 bg-orange-500/10' : 'text-gray-400 hover:text-white hover:bg-white/5'}",
                    data: { turbo: true } do %>
                  <div class="w-2 h-2 rounded-full <%= User::STATUS_COLORS[key.to_s] %> shrink-0"></div>
                  <%= User::STATUS_LABELS[key.to_s] %>
                  <% if current_user.status == key.to_s %>
                    <svg class="w-3.5 h-3.5 ml-auto text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                  <% end %>
                <% end %>
              <% end %>
            </div>
            <%= link_to "Perfil", profile_path, class: "no-underline text-gray-300 text-sm font-semibold px-2 transition-colors duration-200 hover:text-orange-400" %>
          </div>
          <div class="w-px h-5 bg-gray-800"></div>
          <%= button_to session_path, method: :delete, form: { data: { turbo: false } },
              class: "bg-gradient-to-r from-red-500 to-red-600 text-white border-none px-7 py-3 rounded-xl text-xs font-black tracking-wide cursor-pointer uppercase shadow-lg shadow-red-500/25 transition-all duration-300 hover:shadow-red-500/40 hover:scale-105" do %>
            Cerrar sesión
          <% end %>
        <% end %>
      </div>

      <button class="lg:hidden bg-none border-none text-white cursor-pointer p-2 transition-transform duration-200 hover:scale-110"
        @click="mobileOpen = !mobileOpen"
        :aria-expanded="mobileOpen">
        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>

    <div class="lg:hidden border-t border-gray-800 py-3"
      x-show="mobileOpen"
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-4"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 -translate-y-4"
      style="display: none;">
      <div class="flex flex-col gap-2">
        <%= link_to "Inicio", root_path, class: "text-orange-500 no-underline text-base font-bold py-2 transition-colors duration-200 hover:text-orange-400" %>
        <%= link_to "Dashboard", user_dashboard_path, class: "text-gray-400 no-underline text-base font-bold py-2 transition-colors duration-200 hover:text-orange-400" %>
        <button @click="contactOpen = !contactOpen; mobileOpen = false"
                class="text-gray-400 text-base font-bold py-2 transition-colors duration-200 hover:text-orange-400 cursor-pointer border-none bg-transparent text-left">
          Contáctanos
        </button>
        <% if authenticated? %>
          <%= link_to notifications_path, class: "text-gray-400 no-underline text-base font-bold py-2 transition-colors duration-200 hover:text-orange-400 flex items-center gap-2" do %>
            Notificaciones
            <% unread_count = current_user.notifications.unread.count %>
            <span data-notifications-target="badge"
                  class="<%= unread_count > 0 ? '' : 'hidden' %> w-4 h-4 rounded-full bg-orange-500 text-black text-[9px] font-black flex items-center justify-center"><%= unread_count > 9 ? "9+" : unread_count %></span>
          <% end %>
          <div class="border-t border-gray-800 pt-3 flex flex-col gap-1">
            <div class="text-[11px] font-black text-gray-500 uppercase tracking-wider px-1 mb-1">Estado</div>
            <% User::STATUSES.slice(:disponible, :ausente, :no_molestar).each do |key, val| %>
              <%= button_to profile_status_path, method: :patch, params: { status: key },
                  class: "w-full flex items-center gap-2.5 px-3 py-2.5 text-sm font-semibold text-left transition-all duration-150 border-none bg-transparent cursor-pointer rounded-lg #{current_user.status == key.to_s ? 'text-orange-400 bg-orange-500/10' : 'text-gray-400 hover:text-white hover:bg-white/5'}" do %>
                <div class="w-2 h-2 rounded-full <%= User::STATUS_COLORS[key.to_s] %> shrink-0"></div>
                <%= User::STATUS_LABELS[key.to_s] %>
                <% if current_user.status == key.to_s %>
                  <svg class="w-3.5 h-3.5 ml-auto text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                <% end %>
              <% end %>
            <% end %>
          </div>
          <div class="flex gap-3 pt-3 border-t border-gray-800">
            <%= link_to "Perfil", profile_path, class: "text-white no-underline text-base font-bold py-2 transition-colors duration-200 hover:text-orange-400" %>
            <%= button_to "Cerrar sesión", session_path, method: :delete, form: { data: { turbo: false } },
                class: "bg-gradient-to-r from-red-500 to-red-600 text-white border-none px-5 py-2 rounded-lg text-sm font-bold cursor-pointer shadow-lg shadow-red-500/25 transition-all duration-300 hover:scale-105" %>
          </div>
        <% else %>
          <%= link_to "Iniciar sesión", new_session_path,
              class: "bg-gradient-to-r from-orange-500 to-orange-600 text-white no-underline px-6 py-3 rounded-lg text-sm font-bold text-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:scale-105" %>
        <% end %>
      </div>
    </div>
  </div>

  <%# Contact Popup %>
  <div x-show="contactOpen"
       x-cloak
       @keydown.escape.window="contactOpen = false"
       class="fixed inset-0 z-[9999] w-screen h-screen">
    <div x-show="contactOpen"
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100"
         @click="contactOpen = false"
         class="absolute inset-0 bg-black/80 backdrop-blur-md cursor-pointer">
    </div>
    <div class="relative w-full h-full flex items-center justify-center p-2 sm:p-4">
      <div @click.away="contactOpen = false"
           x-show="contactOpen"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-90"
           x-transition:enter-end="opacity-100 scale-100"
           class="bg-black/90 backdrop-blur-xl border border-white/10 rounded-2xl w-full max-w-md max-h-[90vh] sm:max-h-[85vh] overflow-y-auto shadow-2xl relative cursor-default mx-2 sm:mx-0"
           style="box-shadow: 0 0 50px rgba(255,107,0,0.1), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

        <div class="flex items-center justify-between p-5 lg:p-6 border-b border-white/5">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/20">
              <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <h3 class="text-lg font-black text-white m-0">Contáctanos</h3>
          </div>
          <button @click="contactOpen = false"
                  class="bg-none border-none text-gray-500 cursor-pointer p-1.5 rounded-lg transition-all duration-200 hover:text-orange-400 hover:bg-white/5">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <div class="p-5 lg:p-6 flex flex-col gap-5">

          <% if authenticated? && current_user.branch.present? %>
            <div class="bg-white/5 border border-white/10 rounded-xl p-4">
              <h4 class="text-[11px] font-black text-orange-500 uppercase tracking-wider mb-3">Tu sucursal</h4>
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shrink-0 shadow-lg shadow-orange-500/20 mt-0.5">
                  <svg class="w-4 h-4 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div class="min-w-0">
                  <div class="font-bold text-white text-sm"><%= current_user.branch.name %></div>
                  <div class="text-gray-500 text-xs mt-0.5"><%= current_user.branch.address %></div>
                  <div class="text-gray-500 text-xs mt-0.5"><%= current_user.branch.phone %></div>
                  <div class="flex items-center gap-1.5 mt-1.5">
                    <div class="w-1.5 h-1.5 rounded-full <%= current_user.branch.enabled ? 'bg-green-500' : 'bg-red-500' %>"></div>
                    <span class="text-[10px] font-bold uppercase <%= current_user.branch.enabled ? 'text-green-400' : 'text-red-400' %>">
                      <%= current_user.branch.enabled ? "Abierta" : "Cerrada" %>
                    </span>
                  </div>
                </div>
              </div>
            </div>
          <% end %>

          <div>
            <h4 class="text-[11px] font-black text-orange-500 uppercase tracking-wider mb-3">Envíanos un mensaje</h4>
            <form action="<%= contact_path %>" method="post" class="flex flex-col gap-3">
              <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
              <input type="text" name="name" required placeholder="Tu nombre"
                     class="w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600">
              <input type="email" name="email" required placeholder="Tu correo electrónico"
                     class="w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600">
              <textarea name="message" required rows="4" placeholder="Escribe tu mensaje..."
                        class="w-full p-3 border border-white/10 rounded-xl bg-white/5 text-white text-sm outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)] placeholder-gray-600 resize-none"></textarea>
              <button type="submit"
                      class="bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-3 rounded-xl text-sm font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.02] active:scale-[0.98]">
                Enviar mensaje
              </button>
            </form>
          </div>

          <div class="text-center border-t border-white/5 pt-4">
            <p class="text-gray-600 text-xs m-0">
              O escríbenos directamente a
              <a href="mailto:contacto@biohealthgroup.com.uy" class="text-orange-500 no-underline hover:text-orange-400">contacto@biohealthgroup.com.uy</a>
            </p>
          </div>

        </div>
      </div>
    </div>
  </div>
</nav>
