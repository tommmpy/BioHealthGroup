<% flash.each do |key, msg| %>
  <% next if msg.blank? %>
  <%
    styles = case key.to_s
    when "notice" then "bg-green-500/10 border-green-500/30 text-green-400 shadow-green-500/5"
    when "alert"  then "bg-red-500/10 border-red-500/30 text-red-400 shadow-red-500/5"
    else "bg-orange-500/10 border-orange-500/30 text-orange-400 shadow-orange-500/5"
    end
    icon = case key.to_s
    when "notice" then '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>'
    when "alert"  then '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86l-8.2 14.2A1 1 0 003 20h18a1 1 0 00.86-1.49l-8.2-14.2a1 1 0 00-1.72 0z"/>'
    else '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>'
    end
  %>
  <div x-data="{ show: true }"
       x-show="show"
       x-init="setTimeout(() => show = false, 4500)"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0 translate-x-4"
       x-transition:enter-end="opacity-100 translate-x-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="opacity-100 translate-x-0"
       x-transition:leave-end="opacity-0 translate-x-4"
       class="fixed top-14 sm:top-16 right-4 z-[110] w-auto max-w-sm pointer-events-auto">
    <div class="<%= styles %> px-4 py-3 rounded-xl text-xs sm:text-sm font-semibold shadow-xl backdrop-blur-xl flex items-center gap-3 border">
      <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><%= icon.html_safe %></svg>
      <span class="break-words leading-snug flex-1"><%= msg %></span>
      <button @click="show = false" class="shrink-0 opacity-60 hover:opacity-100 transition-opacity bg-transparent border-none cursor-pointer p-0.5 rounded" aria-label="Cerrar">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
  </div>
<% end %>
