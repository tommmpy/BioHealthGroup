<section x-data="{
    current: 0,
    total: <%= @hero_slides.any? ? @hero_slides.size : 1 %>,
    timer: null,
    start() { this.timer = setInterval(() => { this.current = (this.current + 1) % this.total }, 5500) },
    stop() { clearInterval(this.timer); this.timer = null },
    go(i) { this.stop(); this.current = i; this.start() }
  }" x-init="start()"
  class="relative overflow-hidden rounded-b-2xl mb-6 lg:mb-10 min-h-[300px] sm:min-h-[420px] lg:min-h-[520px] flex items-center">

  <% if @hero_slides.any? %>
    <% @hero_slides.each_with_index do |slide, i| %>
      <div x-show="current === <%= i %>"
           x-transition:enter="transition ease-out duration-500"
           x-transition:enter-start="opacity-0 translate-y-4"
           x-transition:enter-end="opacity-100 translate-y-0"
           x-transition:leave="transition ease-in duration-300"
           x-transition:leave-start="opacity-100"
           x-transition:leave-end="opacity-0"
           class="absolute inset-0 flex items-center"
           style="<%= slide.image.attached? ? "background-image: url(#{url_for(slide.image)}); background-size: cover; background-position: center; border-radius: 0 0 24px 24px;" : "background: #080808; border-radius: 0 0 24px 24px;" %>">
        <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-black/70"></div>
        <div class="max-w-6xl mx-auto px-6 lg:px-10 py-10 lg:py-24 w-full relative z-10">
          <div class="max-w-3xl">
            <div class="flex items-center gap-2 text-orange-400 text-[11px] font-black uppercase tracking-[0.2em] mb-4 lg:mb-6">
              <span class="w-6 h-px bg-orange-500/50"></span>
              BioHealth Group
            </div>
            <h1 class="text-3xl lg:text-6xl font-[900] text-white leading-[1.1] mb-4 lg:mb-6">
              <%= slide.title %>
            </h1>
            <% if slide.subtitle.present? %>
              <p class="text-gray-300 text-sm lg:text-lg leading-relaxed max-w-2xl mb-6 lg:mb-8">
                <%= slide.subtitle %>
              </p>
            <% end %>
            <% if slide.cta_text.present? %>
              <%= link_to slide.cta_link || user_dashboard_path,
                  class: "group inline-flex items-center gap-2.5 bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 lg:px-9 py-3 lg:py-4 rounded-xl font-black text-sm lg:text-base shadow-xl shadow-orange-500/30 transition-all duration-300 hover:shadow-orange-500/50 hover:scale-105" do %>
                <%= slide.cta_text %>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="absolute inset-0"
         style="background: radial-gradient(ellipse at 20% 50%, rgba(255,107,0,0.12) 0%, transparent 50%), radial-gradient(ellipse at 80% 0%, rgba(255,107,0,0.06) 0%, transparent 40%), #080808;">
      <div class="absolute inset-0 bg-gradient-to-r from-black/70 via-black/40 to-transparent"></div>
    </div>
    <div class="max-w-6xl mx-auto px-6 lg:px-10 py-10 lg:py-24 w-full relative z-10">
      <div class="max-w-3xl">
        <div class="flex items-center gap-2 text-orange-400 text-[11px] font-black uppercase tracking-[0.2em] mb-4 lg:mb-6">
          <span class="w-6 h-px bg-orange-500/50"></span>
          BioHealth Group
        </div>
        <h1 class="text-3xl lg:text-6xl font-[900] text-white leading-[1.1] mb-4 lg:mb-6">
          Estudio y Valoración Biomécanica
        </h1>
        <p class="text-gray-300 text-sm lg:text-lg leading-relaxed max-w-2xl mb-6 lg:mb-8">
          Tecnología de punta para el análisis del movimiento. Representantes exclusivos de <strong class="text-white">Sensor Medica Italia</strong> en Uruguay.
        </p>
        <div class="flex flex-wrap items-center gap-4">
          <%= link_to user_dashboard_path,
              class: "group inline-flex items-center gap-2.5 bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-6 lg:px-9 py-3 lg:py-4 rounded-xl font-black text-sm lg:text-base shadow-xl shadow-orange-500/30 transition-all duration-300 hover:shadow-orange-500/50 hover:scale-105" do %>
            Agendar Estudio
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @hero_slides.many? %>
    <div class="absolute bottom-6 lg:bottom-8 left-1/2 -translate-x-1/2 flex items-center gap-2.5 z-20">
      <% @hero_slides.each_with_index do |slide, i| %>
        <button @click="go(<%= i %>)"
                class="h-1.5 rounded-full border-none cursor-pointer transition-all duration-500"
                :class="current === <%= i %> ? 'w-10 bg-orange-500 shadow-lg shadow-orange-500/40' : 'w-1.5 bg-white/20 hover:bg-white/40'">
        </button>
      <% end %>
    </div>
  <% end %>
</section>

<section class="py-10 sm:py-14 lg:py-20 px-3 sm:px-4 bg-[#080808] rounded-2xl mb-8 sm:mb-10 lg:mb-12">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-8 sm:mb-10 lg:mb-12">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-4">Mejora tu calidad de vida</h2>
      <p class="text-gray-500 max-w-2xl mx-auto text-sm lg:text-base">En BHG combinamos tecnología de punta con un equipo especializado para transformar tu salud. No solo corregimos tu pisada — <strong class="text-white">revolucionamos tu bienestar integral</strong>.</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 lg:gap-8">
      <% [
        { title: "Prevención de Dolores", desc: "Elimina molestias en rodillas, cadera y espalda baja causadas por una mala postura.", icon_path: "M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
        { title: "Rendimiento Deportivo", desc: "Optimizamos el apoyo para deportistas de alto rendimiento y amateurs.", icon_path: "M13 10V3L4 14h7v7l9-11h-7z" },
        { title: "Tecnología CAD-CAM", desc: "Diseño digital exacto para una adaptación perfecta a tu anatomía.", icon_path: "M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" }
      ].each do |item| %>
        <div class="group bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 lg:p-10 relative transition-all duration-500 hover:border-orange-500/30 hover:shadow-2xl hover:shadow-orange-500/5"
             style="box-shadow: 0 0 20px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
          <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10 opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center mb-5 shadow-lg shadow-orange-500/20">
            <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon_path] %>"/></svg>
          </div>
          <h3 class="text-white text-xl font-bold mb-4"><%= item[:title] %></h3>
          <p class="text-gray-500 leading-relaxed text-sm lg:text-base"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>

  </div>
</section>

<% if @process_steps.any? %>
<section class="py-10 sm:py-14 lg:py-20 px-3 sm:px-4 max-w-6xl mx-auto mb-8 sm:mb-10 lg:mb-12">
  <div class="text-center mb-8 sm:mb-10 lg:mb-12">
      <h2 class="text-2xl sm:text-3xl lg:text-4xl font-black text-white mb-4">¿Cómo funciona nuestro servicio?</h2>
    <p class="text-gray-500 max-w-lg mx-auto text-sm lg:text-base">Un proceso completo desde el estudio biomecánico hasta el producto final.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6 lg:gap-8">
    <% @process_steps.each do |step| %>
      <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 text-center transition-all duration-300 hover:border-orange-500/20"
           style="box-shadow: 0 0 20px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

        <% if step.image.attached? %>
          <div class="mx-auto mb-5 max-w-[144px] relative">
            <%= image_tag step.image, class: "w-full h-auto rounded-lg" %>
            <div class="absolute -top-2 -right-2 w-8 h-8 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/30">
              <span class="text-black text-xs font-black"><%= step.step_number %></span>
            </div>
          </div>
        <% else %>
          <div class="w-14 h-14 mx-auto mb-5 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/20">
            <span class="text-black text-lg font-black"><%= step.step_number %></span>
          </div>
        <% end %>

        <h3 class="text-white text-lg font-bold mb-3 leading-snug"><%= step.title %></h3>
        <% if step.description.present? %>
          <p class="text-gray-500 text-sm leading-relaxed"><%= step.description %></p>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
<% end %>

<% if @testimonials.any? %>
<section class="py-10 sm:py-14 lg:py-20 px-3 sm:px-4 bg-[#080808] rounded-2xl mb-8 sm:mb-10 lg:mb-12">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-8 sm:mb-10 lg:mb-12">
      <h2 class="text-3xl lg:text-4xl font-black text-white mb-4">Lo que dicen nuestros pacientes</h2>
      <p class="text-gray-500 max-w-lg mx-auto text-sm lg:text-base">Historias reales de personas que transformaron su calidad de vida con BHG.</p>
    </div>

    <div x-data="{
      current: 0,
      total: <%= @testimonials.length %>,
      timer: null,
      h: 0,
      start() { this.timer = setInterval(() => { this.current = (this.current + 1) % this.total }, 5000) },
      stop() { clearInterval(this.timer); this.timer = null },
      go(i) { this.stop(); this.current = i; this.start() }
    }" x-init="
      start();
      $nextTick(() => {
        const slides = $el.querySelectorAll('[data-slide]');
        let max = 0;
        slides.forEach(s => {
          const prev = s.style.display;
          s.style.display = 'block';
          s.style.position = 'absolute';
          s.style.visibility = 'hidden';
          max = Math.max(max, s.scrollHeight);
          s.style.display = prev;
          s.style.position = '';
          s.style.visibility = '';
        });
        h = max || 360;
      });
    " class="max-w-3xl mx-auto">
      <div :style="`height: ${h}px`" class="relative overflow-hidden">
        <% @testimonials.each_with_index do |testimonial, i| %>
          <div data-slide
               x-show="current === <%= i %>"
               x-transition:enter="transition ease-out duration-500"
               x-transition:enter-start="opacity-0"
               x-transition:enter-end="opacity-100"
               x-transition:leave="transition ease-in duration-300"
               x-transition:leave-start="opacity-100"
               x-transition:leave-end="opacity-0"
               class="absolute inset-0">
            <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-8 lg:p-10 text-center"
                 style="box-shadow: 0 0 20px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
              <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
              <svg class="w-10 h-10 text-orange-500/20 mx-auto mb-6" fill="currentColor" viewBox="0 0 24 24"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>
              <p class="text-gray-300 text-base lg:text-lg leading-relaxed mb-8 italic">"<%= testimonial.content %>"</p>
              <div class="flex items-center justify-center gap-4">
                <% if testimonial.avatar.attached? %>
                  <div class="w-14 h-14 rounded-full overflow-hidden border-2 border-orange-500/30 shrink-0">
                    <%= image_tag testimonial.avatar, class: "w-full h-full object-cover" %>
                  </div>
                <% else %>
                  <div class="w-14 h-14 rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-black text-xl font-black shrink-0 shadow-lg shadow-orange-500/20">
                    <%= testimonial.author_name.first %>
                  </div>
                <% end %>
                <div class="text-left">
                  <div class="font-bold text-white text-base"><%= testimonial.author_name %></div>
                  <% if testimonial.author_role.present? %>
                    <div class="text-[11px] font-black text-orange-500 uppercase tracking-wider mt-0.5"><%= testimonial.author_role %></div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <% if @testimonials.many? %>
        <div class="flex items-center justify-center gap-2.5 mt-8">
          <% @testimonials.each_with_index do |_, i| %>
            <button @click="go(<%= i %>)"
                    class="h-1.5 rounded-full border-none cursor-pointer transition-all duration-500"
                    :class="current === <%= i %> ? 'w-8 bg-orange-500 shadow-lg shadow-orange-500/30' : 'w-1.5 bg-white/20 hover:bg-white/40'">
            </button>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</section>
<% end %>
<section class="py-10 sm:py-14 lg:py-20 px-3 sm:px-4 max-w-6xl mx-auto mb-8 sm:mb-10 lg:mb-12">
  <div class="flex items-center gap-4 mb-8 sm:mb-10 lg:mb-12">
    <div class="w-1 h-8 bg-gradient-to-b from-orange-500 to-orange-600 rounded-full shrink-0"></div>
    <div>
      <div class="text-[10px] font-black text-orange-500 uppercase tracking-widest mb-1">Ubicaciones</div>
      <h2 class="text-2xl lg:text-3xl font-black text-white m-0">Nuestras Sucursales</h2>
    </div>
  </div>

  <% initial_limit = 6 %>
  <div x-data="{ showAll: false }">
    <div class="relative">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 lg:gap-6">
        <% @branches.each_with_index do |branch, i| %>
      <div x-show="showAll || <%= i %> < <%= initial_limit %>"
           x-transition:enter="transition ease-out duration-300"
           x-transition:enter-start="opacity-0 scale-95"
           x-transition:enter-end="opacity-100 scale-100"
           class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative overflow-hidden transition-all duration-300 hover:border-orange-500/20 hover:scale-[1.01]"
           style="box-shadow: 0 0 20px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
        <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
        <% if branch.enabled %>
          <div class="absolute top-5 right-5 flex items-center gap-1.5">
            <div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></div>
            <span class="text-[10px] text-green-500 font-bold uppercase tracking-wider">Disponible</span>
          </div>
        <% end %>

        <h3 class="text-white text-xl lg:text-2xl font-bold mb-5"><%= branch.name %></h3>

        <div class="flex flex-col gap-3 lg:gap-4">
          <div class="flex items-center gap-3 text-gray-400">
            <svg class="w-[18px] h-[18px] text-orange-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-sm"><%= branch.address %></span>
          </div>
          <div class="flex items-center gap-3 text-gray-400">
            <svg class="w-[18px] h-[18px] text-orange-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="text-sm"><%= branch.phone %></span>
          </div>
        </div>

        <div class="mt-6 h-32 lg:h-24 bg-black/50 rounded-xl overflow-hidden border border-white/5"
             data-controller="branch-map"
             data-branch-map-address-value="<%= branch.address %>"></div>
      </div>
    <% end %>
      </div>

      <% if @branches.size > initial_limit %>
        <div x-show="!showAll"
             class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-black via-black/80 to-transparent pointer-events-none"></div>
      <% end %>
    </div>

    <% if @branches.size > initial_limit %>
      <div class="text-center mt-6 lg:mt-8">
        <button @click="showAll = !showAll"
                class="group bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-8 py-3.5 rounded-xl text-sm font-black uppercase tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 active:scale-[0.98] inline-flex items-center gap-2">
          <span x-text="showAll ? 'Ver menos' : 'Ver más sucursales'"></span>
          <svg class="w-4 h-4 transition-transform duration-300" :class="showAll ? 'rotate-180' : ''" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/></svg>
        </button>
      </div>
    <% end %>
  </div>
</section>

<section class="py-10 sm:py-14 lg:py-20 px-3 sm:px-4 text-center rounded-2xl rounded-b-none relative overflow-hidden"
         style="background: radial-gradient(ellipse at 50% 0%, rgba(255,107,0,0.08) 0%, transparent 60%);">
  <div class="max-w-4xl mx-auto relative z-10">
    <h2 class="text-3xl lg:text-4xl font-black text-white mb-4">Agenda tu Estudio Biomecánico</h2>
    <p class="text-gray-500 max-w-lg mx-auto text-sm lg:text-base mb-8">En cualquiera de nuestras sucursales en todo el país. Primera evaluación sin cargo.</p>
    <%= link_to user_dashboard_path,
        class: "group bg-gradient-to-r from-orange-500 to-orange-600 text-black px-10 lg:px-14 py-5 lg:py-6 rounded-xl font-black no-underline inline-flex items-center gap-3 shadow-xl shadow-orange-500/30 text-sm lg:text-base transition-all duration-300 hover:shadow-orange-500/50 hover:scale-105 animate-glow-pulse" do %>
      SOLICITAR VALORACIÓN BIOMECÁNICA
      <svg class="w-5 h-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
    <% end %>
  </div>
</section>
