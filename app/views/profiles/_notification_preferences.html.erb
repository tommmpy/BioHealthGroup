<%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-4" do |f| %>
  <%= f.fields_for :notification_preference do |np| %>
    <div class="space-y-4">
      <label class="flex items-center gap-3 cursor-pointer group">
        <%= np.check_box :email_notifications, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-orange-500 focus:ring-orange-500/50 focus:ring-offset-0 cursor-pointer" %>
        <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">Recibir notificaciones por email</span>
      </label>

      <label class="flex items-center gap-3 cursor-pointer group">
        <%= np.check_box :in_app_notifications, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-orange-500 focus:ring-orange-500/50 focus:ring-offset-0 cursor-pointer" %>
        <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">Recibir notificaciones en la app</span>
      </label>

      <label class="flex items-center gap-3 cursor-pointer group">
        <%= np.check_box :reminder_estudios, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-orange-500 focus:ring-orange-500/50 focus:ring-offset-0 cursor-pointer" %>
        <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">Recordatorio de estudios pendientes</span>
      </label>

      <label class="flex items-center gap-3 cursor-pointer group">
        <%= np.check_box :reminder_appointments, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-orange-500 focus:ring-orange-500/50 focus:ring-offset-0 cursor-pointer" %>
        <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">Recordatorio de citas</span>
      </label>

      <label class="flex items-center gap-3 cursor-pointer group">
        <%= np.check_box :marketing_emails, class: "w-4 h-4 rounded border-white/20 bg-white/5 text-orange-500 focus:ring-orange-500/50 focus:ring-offset-0 cursor-pointer" %>
        <span class="text-sm font-medium text-gray-300 group-hover:text-white transition-colors">Recibir correos de marketing y promociones</span>
      </label>
    </div>
  <% end %>

  <div class="pt-4">
    <%= f.submit "Guardar preferencias", class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none px-6 py-2.5 rounded-xl text-sm font-bold cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105 active:scale-[0.98]" %>
  </div>
<% end %>
