<div class="max-w-2xl mx-auto my-8 lg:my-10 px-4 animate-fade-up">

  <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 lg:p-6 mb-8 lg:mb-10 flex flex-col sm:flex-row justify-between sm:items-end gap-4 relative"
       style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
    <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
    <div>
      <h1 class="text-2xl lg:text-3xl font-black text-white m-0 tracking-tight">Configuración de cuenta</h1>
      <p class="text-gray-400 text-sm mt-1 font-medium">Gestiona tu información personal y de contacto.</p>
    </div>
    <%= link_to edit_profile_path, class: "bg-gradient-to-r from-orange-500 to-orange-600 text-black no-underline px-5 py-3 rounded-xl text-sm font-bold shadow-lg shadow-orange-500/25 shrink-0 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-105" do %>
      <span class="flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
        Editar perfil
      </span>
    <% end %>
  </div>

  <div class="flex flex-col gap-6 lg:gap-8">

    <section class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-6 lg:p-8 relative"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="flex items-center gap-5 lg:gap-6 mb-6 lg:mb-8">
        <div class="h-[70px] lg:h-[90px] w-[70px] lg:w-[90px] rounded-full bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center text-2xl lg:text-3xl font-black text-black border-2 border-white/20 shrink-0 shadow-lg shadow-orange-500/20">
          <%= @user.first_name[0] %><%= @user.last_name[0] %>
        </div>
        <div class="min-w-0">
          <h2 class="text-xl lg:text-2xl font-bold text-white m-0 truncate"><%= @user.first_name %> <%= @user.last_name %></h2>
          <span class="inline-block mt-2 bg-gradient-to-r from-orange-500 to-orange-600 text-black text-[11px] font-bold px-3 py-1 rounded-lg uppercase tracking-wider shadow-lg shadow-orange-500/20">
            <%= @user.role %>
          </span>
        </div>
      </div>

      <div class="flex items-center gap-3 mb-5 pb-5 border-b border-orange-500/20">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded-full <%= User::STATUS_COLORS[@user.status] || 'bg-gray-600' %> shadow-lg shadow-current/20"></div>
          <span class="text-sm font-bold text-gray-300"><%= @user.status_label %></span>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 lg:gap-8">
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Cédula de Identidad</label>
          <span class="text-base font-semibold text-white"><%= @user.ci %></span>
        </div>

        <% if @user.branch %>
        <div>
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Sucursal asignada</label>
          <div class="bg-white/5 p-4 rounded-xl border border-white/10 transition-all duration-200 hover:border-orange-500/20">
            <div class="flex justify-between items-start">
              <span class="text-sm font-bold text-white"><%= @user.branch.name %></span>
              <span class="text-[10px] font-bold uppercase <%= @user.branch.enabled ? 'text-green-400' : 'text-red-400' %>">
                <%= @user.branch.enabled ? "Activa" : "Inactiva" %>
              </span>
            </div>
            <div class="flex items-center gap-1.5 mt-1">
              <svg class="w-3.5 h-4 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.89a1 1 0 01.95.68l1.498 4a1 1 0 01-.45 1.21l-2.8 1.4a11.042 11.042 0 005.516 5.517l1.4-2.8a1 1 0 011.21-.45l4 1.499a1 1 0 01.68.95V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <p class="text-sm text-gray-500 m-0"><%= @user.branch.phone %></p>
            </div>

            <%= link_to "https://www.google.com/maps/search/?api=1&query=#{u(@user.branch.address + " Uruguay")}", target: "_blank",
                class: "flex items-center gap-2 bg-white/5 border border-white/10 rounded-xl px-4 py-3 mt-4 no-underline transition-all duration-200 hover:bg-orange-500/5 hover:border-orange-500/30 hover:scale-[1.01] group" do %>
              <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shrink-0 shadow-lg shadow-orange-500/20">
                <svg class="w-5 h-5 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" stroke-width="2"/>
                </svg>
              </div>
              <div class="flex flex-col">
                <span class="text-sm font-bold text-white group-hover:text-orange-400 transition-colors">Ver ubicación en Google Maps</span>
                <span class="text-[10px] text-gray-500"><%= @user.branch.address %></span>
              </div>
              <svg class="w-4 h-4 text-gray-600 ml-auto shrink-0 group-hover:text-orange-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            <% end %>
          </div>
        </div>
        <% end %>
      </div>
    </section>

    <section class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl overflow-hidden relative"
             style="box-shadow: 0 0 30px rgba(255,107,0,0.03), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>
      <div class="px-5 lg:px-8 py-5 border-b border-white/5">
        <h3 class="text-base font-bold text-white m-0">Datos de Contacto</h3>
      </div>

      <div class="px-5 lg:px-8 py-2.5">
        <div class="flex flex-col sm:flex-row sm:items-center py-5 border-b border-white/5 gap-1 sm:gap-0">
          <div class="sm:w-1/3 text-xs font-bold text-gray-500">Email</div>
          <div class="sm:w-2/3 text-sm font-semibold text-white break-all"><%= @user.email_address %></div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-center py-5 border-b border-white/5 gap-1 sm:gap-0">
          <div class="sm:w-1/3 text-xs font-bold text-gray-500">Teléfono</div>
          <div class="sm:w-2/3 text-sm font-semibold text-white"><%= @user.phone_number %></div>
        </div>
        <% if @user.contacto_root.present? %>
        <div class="flex flex-col sm:flex-row sm:items-center py-5 border-b border-white/5 gap-1 sm:gap-0">
          <div class="sm:w-1/3 text-xs font-bold text-gray-500"><%= @user.empresa? ? "Empresa / Razón social" : "Contacto emergencia" %></div>
          <div class="sm:w-2/3 text-sm font-semibold text-white"><%= @user.contacto_root %></div>
        </div>
        <% end %>
        <div class="flex flex-col sm:flex-row sm:items-start py-5 gap-1 sm:gap-0">
          <div class="sm:w-1/3 text-xs font-bold text-gray-500">Dirección</div>
          <div class="sm:w-2/3 text-sm font-semibold text-white leading-relaxed"><%= @user.address %></div>
        </div>
      </div>
    </section>

  </div>
</div>
