<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-sm relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl sm:rounded-3xl p-6 sm:p-8 lg:p-10 relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl sm:rounded-3xl -z-10"></div>

      <div class="text-center mb-8">
        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:scale-105 hover:shadow-orange-500/40">
          <svg class="w-8 h-8 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <h1 class="text-xl sm:text-2xl font-black text-white tracking-tight">Iniciar sesión</h1>
        <p class="text-gray-500 text-sm mt-1.5">Accedé al ecosistema BioHealthGroup</p>
      </div>

      <%= form_with url: session_path, id: "login_form", data: { turbo: false } do |f| %>
        <div class="flex flex-col gap-5">
          <div>
            <%= f.label :email_address, "Correo electrónico", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-2" %>
            <%= f.email_field :email_address,
                            value: params[:email_address],
                            required: true,
                            autofocus: true,
                            placeholder: "tu@email.com",
                            class: "w-full p-3.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>

          <div>
            <div class="flex justify-between items-center mb-2">
              <%= f.label :password, "Contraseña", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider" %>
              <%= link_to "¿Olvidaste?", new_password_path,
                  class: "text-xs text-gray-500 no-underline font-semibold transition-colors duration-200 hover:text-orange-400" %>
            </div>
            <%= f.password_field :password,
                                required: true,
                                placeholder: "••••••••",
                                class: "w-full p-3.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>

          <%= f.submit "ENTRAR AL SISTEMA",
                   class: "w-full mt-1 bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-3.5 rounded-xl text-sm font-black tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.01] active:scale-[0.99]" %>
        </div>
      <% end %>

      <div class="mt-8 pt-6 border-t border-white/5 text-center">
        <p class="text-sm text-gray-500">
          ¿Aún no tenés cuenta?
        </p>
        <%= link_to new_registration_path,
            class: "mt-3 inline-flex items-center gap-2 text-white no-underline text-sm font-bold border-b-2 border-orange-500/40 pb-0.5 transition-all duration-200 hover:border-orange-500 hover:text-orange-400" do %>
          Crear cuenta
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
