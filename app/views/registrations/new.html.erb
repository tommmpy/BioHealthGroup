<div class="min-h-[calc(100vh-5rem)] flex items-center justify-center px-3 sm:px-4 -mt-3">
  <div class="absolute inset-0 bg-gradient-to-b from-orange-500/8 via-transparent to-transparent pointer-events-none"></div>

  <div class="w-full max-w-xl relative animate-fade-up">
    <div class="absolute -top-20 -left-20 w-40 h-40 bg-orange-500/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-orange-500/5 rounded-full blur-3xl"></div>

    <div class="bg-black/80 backdrop-blur-xl border border-white/10 rounded-2xl p-4 sm:p-6 relative transition-all duration-300 hover:border-orange-500/20"
         style="box-shadow: 0 0 40px rgba(255,107,0,0.05), inset 0 1px 0 rgba(255,255,255,0.05);">
      <div class="absolute inset-0 bg-gradient-to-b from-orange-500/3 to-transparent rounded-2xl -z-10"></div>

      <div class="text-center mb-5">
        <div class="w-12 h-12 mx-auto mb-3 rounded-xl bg-gradient-to-br from-orange-500 to-orange-600 flex items-center justify-center shadow-lg shadow-orange-500/25 transition-all duration-300 hover:scale-105">
          <svg class="w-6 h-6 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
          </svg>
        </div>
        <h1 class="text-lg sm:text-xl font-black text-white tracking-tight">Crear cuenta</h1>
        <p class="text-gray-500 text-xs sm:text-sm mt-1">Completá tus datos para empezar tu tratamiento</p>
      </div>

      <%= form_with model: @user, url: registrations_path do |f| %>
        <% if @user.errors.any? %>
          <div class="bg-red-950/80 backdrop-blur-sm border border-red-900/50 p-3 rounded-xl mb-4">
            <p class="text-red-400 text-xs font-bold mb-1">Revisá los siguientes campos:</p>
            <ul class="m-0 pl-4 text-gray-300 text-xs">
              <% @user.errors.full_messages.each do |msg| %>
                <li class="mb-0.5"><%= msg %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <%= f.label :first_name, "Nombres", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.text_field :first_name, placeholder: "Ej: Juan Román", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <%= f.label :last_name, "Apellidos", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.text_field :last_name, placeholder: "Ej: Riquelme", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <%= f.label :ci, "Cédula de Identidad", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.text_field :ci, placeholder: "Sin puntos", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <%= f.label :phone_number, "Teléfono", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.telephone_field :phone_number, placeholder: "099 123 456", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div class="sm:col-span-2">
            <%= f.label :email_address, "Correo electrónico", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.email_field :email_address, placeholder: "tu@email.com", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div>
            <%= f.label :branch_id, "Sucursal", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <div class="relative">
              <%= f.collection_select :branch_id, Branch.all, :id, :name, { prompt: "Seleccionar" }, class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none appearance-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
              <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-2.5">
                <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M6 9l6 6 6-6"/></svg>
              </div>
            </div>
          </div>
          <div>
            <%= f.label :birthday, "Fecha de nacimiento", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.date_field :birthday, class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]", max: Date.current.iso8601 %>
          </div>
          <div class="sm:col-span-2">
            <%= f.label :address, "Dirección", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.text_field :address, placeholder: "Calle, Nro, Ciudad", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
          <div class="sm:col-span-2">
            <%= f.label :password, "Contraseña", class: "block text-xs font-bold text-gray-500 uppercase tracking-wider mb-1.5" %>
            <%= f.password_field :password, placeholder: "Mínimo 8 caracteres", class: "w-full p-2.5 bg-white/5 border border-white/10 rounded-xl text-sm text-white outline-none transition-all duration-200 placeholder-gray-600 focus:border-orange-500/50 focus:shadow-[0_0_15px_rgba(255,107,0,0.1)]" %>
          </div>
        </div>

        <%= f.submit "FINALIZAR REGISTRO",
                 class: "w-full mt-4 bg-gradient-to-r from-orange-500 to-orange-600 text-black border-none py-3 rounded-xl text-sm font-black tracking-wider cursor-pointer shadow-lg shadow-orange-500/25 transition-all duration-300 hover:shadow-orange-500/40 hover:scale-[1.01] active:scale-[0.99]" %>

        <div class="text-center mt-4 pt-4 border-t border-white/5">
          <p class="text-sm text-gray-500">
            ¿Ya tenés cuenta?
            <%= link_to "Iniciá sesión", new_session_path, class: "text-white no-underline font-bold border-b-2 border-orange-500/40 pb-0.5 transition-all duration-200 hover:border-orange-500 hover:text-orange-400" %>
          </p>
        </div>
      <% end %>
    </div>
  </div>
</div>
