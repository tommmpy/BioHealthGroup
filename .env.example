# =============================================================================
# BioHealthGroup — Required Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for local development.
# For production, set these via Kamal secrets or the hosting environment.

# --- Deployment (Kamal) ---
DEPLOY_SERVER=                     # e.g. 164.90.252.111
APPLICATION_HOST=                  # e.g. biohealthgroup.uy
APPLICATION_URL=                   # e.g. https://biohealthgroup.uy
REGISTRY_SERVER=                   # e.g. ghcr.io
REGISTRY_USER=                     # e.g. your-gh-username
KAMAL_REGISTRY_PASSWORD=           # GitHub personal access token (or Docker Hub password)

# --- Rails ---
RAILS_MASTER_KEY=                  # Contents of config/master.key
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=5

# --- Database ---
BIO_HEALTH_GROUP_DATABASE_PASSWORD=  # Production DB password
DEV_DB_USERNAME=tom                  # Development DB username
DEV_DB_PASSWORD=                     # Development DB password (optional if trust auth)

# --- Active Storage ---
ACTIVE_STORAGE_SERVICE=local         # local (default), amazon, google
# AWS_REGION=us-east-1
# AWS_BUCKET=bio-health-group-production

# --- SMTP Mailer ---
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ADDRESS=smtp.gmail.com
SMTP_PORT=587
SMTP_AUTHENTICATION=plain
MAILER_FROM=noreply@biohealthgroup.uy

# --- Contact Form ---
CONTACT_EMAIL=                      # Where contact form submissions are sent

# --- Solid Queue ---
JOB_CONCURRENCY=1
