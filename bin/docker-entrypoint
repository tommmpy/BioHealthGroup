#!/bin/bash -e

# If running the rails server then prepare all databases
if [ "${@: -2:1}" == "./bin/rails" ] && [ "${@: -1:1}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:create:cache 2>/dev/null || true
  ./bin/rails db:create:queue 2>/dev/null || true
  ./bin/rails db:create:cable 2>/dev/null || true
  ./bin/rails db:migrate:cache 2>/dev/null || true
  ./bin/rails db:migrate:queue 2>/dev/null || true
  ./bin/rails db:migrate:cable 2>/dev/null || true

  # Seed only if branches table is empty (idempotent)
  count=$(./bin/rails runner "puts Branch.count" 2>/dev/null | tail -1)
  if [ "$count" = "0" ]; then
    echo "--- Database empty, running seeds ---"
    ./bin/rails db:seed
  fi
fi

exec "${@}"
